---
/*
 * Auvik-style structured topology: a tiered tree (internet → gateway →
 * switching → networks → devices → VMs) with elbow connectors. Initial
 * layout is computed at build time; client JS handles hover focus and
 * expand/collapse of the Proxmox hosts (the tree re-spaces itself and
 * nodes glide to their new positions).
 *
 * The media Proxmox host and its VMs are described generically on
 * purpose — keep it that way.
 * TODO(briggs): VM names below are placeholders — rename to taste
 * (labels only; ids just need to stay unique).
 */

interface NodeDef {
  id: string;
  label: string;
  c: string;
  r: number;
  blurb: string;
  parent?: string;
  collapsed?: boolean; // starts with children hidden; click to expand
}

const RAW: NodeDef[] = [
  { id: 'internet', label: 'internet', c: 'none', r: 10, blurb: 'ISP uplink. Untrusted by definition — everything below it is policy.' },
  { id: 'gateway', label: 'unifi gateway', c: 'ember', r: 13, parent: 'internet', blurb: 'UniFi gateway — routing, firewall rules, and the segmentation between trusted, IoT, and guest all live here.' },
  { id: 'switch', label: 'unifi switching', c: 'none', r: 9, parent: 'gateway', blurb: 'UniFi switching fabric carrying the networks below.' },

  { id: 'lan', label: 'trusted lan', c: 'moss', r: 10, parent: 'switch', blurb: 'The trusted network — where the fleet lives.' },
  { id: 'iot', label: 'iot', c: 'brass', r: 10, parent: 'switch', blurb: 'Streaming and smart-home devices. They talk out, not sideways.' },
  { id: 'guest', label: 'guest', c: 'frost', r: 10, parent: 'switch', blurb: 'UniFi guest network — visitors get internet and nothing else.' },

  { id: 'pve-media', label: 'pve · media', c: 'iris', r: 8, parent: 'lan', collapsed: true, blurb: 'Proxmox host running NixOS VMs for the media stack — acquisition through playback. Click to expand.' },
  { id: 'vm-media-1', label: 'library', c: 'iris', r: 6, parent: 'pve-media', blurb: 'NixOS VM — the media library and playback service.' },
  { id: 'vm-media-2', label: 'automation', c: 'iris', r: 6, parent: 'pve-media', blurb: 'NixOS VM — keeps the library fed and organized.' },
  { id: 'vm-media-3', label: 'requests', c: 'iris', r: 6, parent: 'pve-media', blurb: 'NixOS VM — where the household asks for things politely.' },

  { id: 'pve-sec', label: 'pve · security', c: 'iris', r: 8, parent: 'lan', collapsed: true, blurb: 'Proxmox host for the security VM deployment — where the day job’s instincts get a sandbox. Click to expand.' },
  { id: 'vm-sec-1', label: 'sensor', c: 'iris', r: 6, parent: 'pve-sec', blurb: 'NixOS VM — network sensor watching the segments.' },
  { id: 'vm-sec-2', label: 'analysis', c: 'iris', r: 6, parent: 'pve-sec', blurb: 'NixOS VM — where captures and alerts get picked apart.' },

  { id: 'pve-net', label: 'pve · netmgmt', c: 'iris', r: 8, parent: 'lan', collapsed: true, blurb: 'Proxmox host for network management VMs — keeping the UniFi estate observable and honest. Click to expand.' },
  { id: 'vm-net-1', label: 'controller', c: 'iris', r: 6, parent: 'pve-net', blurb: 'NixOS VM — network controller and management plane.' },
  { id: 'vm-net-2', label: 'dns', c: 'iris', r: 6, parent: 'pve-net', blurb: 'NixOS VM — internal DNS and the small glue services every lan accretes.' },

  { id: 'gaming', label: 'gaming rig', c: 'iris', r: 8, parent: 'lan', blurb: 'NixOS gaming desktop — proof the declarative life survives contact with GPU drivers.' },
  { id: 'gameserver', label: 'game server', c: 'iris', r: 8, parent: 'lan', blurb: 'GNOME NixOS box hosting game servers — where Gesture’s dedicated builds will land.' },
  { id: 'nas', label: 'nas · ubuntu', c: 'none', r: 8, parent: 'lan', blurb: 'Ubuntu 24.04 LTS NAS — bulk storage, and the one holdout from the NixOS takeover.' },
  { id: 'tv1', label: 'tv', c: 'brass', r: 8, parent: 'iot', blurb: 'Smart TV — quarantined on the IoT network like the chatty appliance it is.' },
  { id: 'tv2', label: 'tv', c: 'brass', r: 8, parent: 'iot', blurb: 'The other smart TV. Same quarantine, same reasons.' },
  { id: 'homepod', label: 'homepod', c: 'brass', r: 8, parent: 'iot', blurb: 'Apple HomePod. It needs to hear "set a timer," not see the lan.' },
  { id: 'guests', label: 'guest devices', c: 'frost', r: 8, parent: 'guest', blurb: 'Whatever friends bring over — captive, segregated, forgotten.' },
];

const W = 960;
const MARGIN = 72;
const TIER_Y = [46, 128, 210, 300, 398, 500];
const VIEW_H = { collapsed: 470, expanded: 560 };

const byId = new Map(RAW.map((n) => [n.id, n]));
const children = new Map<string, NodeDef[]>();
for (const n of RAW) {
  if (n.parent) children.set(n.parent, [...(children.get(n.parent) ?? []), n]);
}

const tierOf = (n: NodeDef): number => (n.parent ? tierOf(byId.get(n.parent)!) + 1 : 0);

const isHidden = (n: NodeDef): boolean => {
  let p = n.parent ? byId.get(n.parent) : undefined;
  while (p) {
    if (p.collapsed) return true;
    p = p.parent ? byId.get(p.parent) : undefined;
  }
  return false;
};

// Layout for the default (collapsed) state: visible leaves evenly
// spaced, parents centered over visible children, hidden nodes parked
// at their parent so they emerge from it on expand.
const visible = RAW.filter((n) => !isHidden(n));
const visLeaves = visible.filter(
  (n) => !(children.get(n.id) ?? []).some((k) => !isHidden(k))
);
const X = new Map<string, number>();
visLeaves.forEach((n, i) =>
  X.set(n.id, MARGIN + (i * (W - MARGIN * 2)) / (visLeaves.length - 1))
);
for (const n of [...visible].sort((a, b) => tierOf(b) - tierOf(a))) {
  const kids = (children.get(n.id) ?? []).filter((k) => !isHidden(k));
  if (kids.length) {
    X.set(n.id, kids.reduce((sum, k) => sum + X.get(k.id)!, 0) / kids.length);
  }
}
for (const n of RAW) {
  if (!X.has(n.id)) X.set(n.id, X.get(n.parent!)!);
}

const nodes = RAW.map((n, i) => ({
  ...n,
  tier: tierOf(n),
  x: X.get(n.id)!,
  y: TIER_Y[tierOf(n)]!,
  hidden: isHidden(n),
  kidCount: (children.get(n.id) ?? []).length,
  labelDy: tierOf(n) >= 4 && i % 2 ? 32 : 18,
}));

const edges = nodes
  .filter((n) => n.parent)
  .map((n) => {
    const p = nodes.find((m) => m.id === n.parent)!;
    const midY = (p.y + n.y) / 2;
    return {
      child: n,
      d: `M ${p.x} ${p.y + p.r} L ${p.x} ${midY} L ${n.x} ${midY} L ${n.x} ${n.y - n.r}`,
    };
  });
---

<figure class="topo">
  <svg id="topo-svg" viewBox={`0 0 ${W} ${VIEW_H.collapsed}`} aria-label="Homelab network topology — tiered map from internet to devices">
    <g>
      {edges.map((e) => (
        <path
          class:list={['edge', `c-${e.child.c}`, { hidden: e.child.hidden }]}
          d={e.d}
          data-edge={e.child.id}
          style={`--t: ${e.child.tier}`}
        />
      ))}
    </g>
    <g>
      {nodes.map((n) => (
        <g
          class:list={['node', `c-${n.c}`, { hidden: n.hidden }]}
          transform={`translate(${n.x} ${n.y})`}
          data-id={n.id}
          data-parent={n.parent}
          data-tier={n.tier}
          data-r={n.r}
          data-label={n.label}
          data-blurb={n.blurb}
          data-expandable={n.collapsed ? '1' : undefined}
          style={`--t: ${n.tier}`}
        >
          <circle class="hit" r={n.r + 13} />
          <circle class="dot" r={n.r} />
          {n.id !== 'internet' && <circle class="up" cx={n.r * 0.8} cy={-n.r * 0.8} r="2.6" />}
          {n.collapsed && <text class="badge" x={n.r + 6} y="4">+{n.kidCount}</text>}
          <text y={n.r + n.labelDy}>{n.label}</text>
        </g>
      ))}
    </g>
  </svg>
  <figcaption id="topo-info">
    Hover a node to inspect it; click a hypervisor to expand its VMs. Green ticks are online status.
  </figcaption>
</figure>

<style is:global>
  .topo {
    margin: 2rem 0;
  }

  #topo-svg {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: 12px;
    user-select: none;
  }

  #topo-svg .c-ember { --nc: var(--ember); }
  #topo-svg .c-iris  { --nc: var(--iris); }
  #topo-svg .c-moss  { --nc: var(--moss); }
  #topo-svg .c-frost { --nc: var(--frost); }
  #topo-svg .c-brass { --nc: var(--brass); }
  #topo-svg .c-none  { --nc: var(--faint); }

  #topo-svg .hidden {
    display: none;
  }

  #topo-svg .edge {
    fill: none;
    stroke: color-mix(in srgb, var(--nc) 32%, var(--line));
    stroke-width: 1.3;
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: topo-draw 700ms ease forwards;
    animation-delay: calc(var(--t) * 150ms);
    transition: opacity 150ms ease, stroke 150ms ease, d 450ms ease;
  }

  #topo-svg .node {
    cursor: default;
    opacity: 0;
    animation: topo-pop 500ms ease forwards;
    animation-delay: calc(var(--t) * 150ms);
    transition: opacity 150ms ease, transform 450ms ease;
  }

  #topo-svg .node[data-expandable] {
    cursor: pointer;
  }

  @keyframes topo-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes topo-pop {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    #topo-svg .edge,
    #topo-svg .node {
      animation: none;
      opacity: 1;
      stroke-dashoffset: 0;
      transition: none;
    }
  }

  #topo-svg .hit {
    fill: transparent;
  }

  #topo-svg .dot {
    fill: color-mix(in srgb, var(--nc) 22%, var(--bg));
    stroke: var(--nc);
    stroke-width: 1.5;
    transition: fill 150ms ease;
  }

  #topo-svg .up {
    fill: var(--moss);
    filter: drop-shadow(0 0 3px var(--moss));
  }

  #topo-svg text {
    font-family: var(--mono);
    font-size: 11px;
    fill: var(--muted);
    text-anchor: middle;
    pointer-events: none;
  }

  #topo-svg .badge {
    font-size: 9px;
    letter-spacing: 0.05em;
    fill: var(--nc);
    text-anchor: start;
  }

  /* Focus mode: dim everything outside the hovered node's path */
  #topo-svg.focused .node:not(.hl) {
    opacity: 0.22;
  }

  #topo-svg.focused .edge:not(.hl) {
    opacity: 0.12;
  }

  #topo-svg .edge.hl {
    stroke: var(--accent);
  }

  #topo-svg .node.hl .dot {
    fill: color-mix(in srgb, var(--nc) 45%, var(--bg));
    filter: drop-shadow(0 0 6px var(--nc));
  }

  #topo-svg .node.hl text {
    fill: var(--text);
  }

  #topo-info {
    min-height: 3.25rem;
    padding: 0.85rem 0.25rem 0;
    font-size: 0.9rem;
    color: var(--muted);
  }

  #topo-info strong {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--accent);
  }
</style>

<script>
  const W = 960;
  const MARGIN = 72;
  const TIER_Y = [46, 128, 210, 300, 398, 500];

  const svg = document.querySelector<SVGSVGElement>('#topo-svg');
  const info = document.querySelector<HTMLElement>('#topo-info');

  if (svg && info) {
    interface Meta {
      id: string;
      el: SVGGElement;
      parent?: string;
      tier: number;
      r: number;
      expandable: boolean;
      badge: SVGTextElement | null;
      x: number;
    }

    const metas: Meta[] = [...svg.querySelectorAll<SVGGElement>('.node')].map((el) => ({
      id: el.dataset.id!,
      el,
      parent: el.dataset.parent || undefined,
      tier: Number(el.dataset.tier),
      r: Number(el.dataset.r),
      expandable: el.dataset.expandable === '1',
      badge: el.querySelector<SVGTextElement>('.badge'),
      x: 0,
    }));
    const byId = new Map(metas.map((m) => [m.id, m]));
    const childrenOf = new Map<string, Meta[]>();
    for (const m of metas) {
      if (m.parent) childrenOf.set(m.parent, [...(childrenOf.get(m.parent) ?? []), m]);
    }
    const edgeEls = [...svg.querySelectorAll<SVGPathElement>('.edge')];

    const collapsed = new Set(metas.filter((m) => m.expandable).map((m) => m.id));

    function hiddenIds() {
      const hidden = new Set<string>();
      for (const m of metas) {
        let p = m.parent ? byId.get(m.parent) : undefined;
        while (p) {
          if (collapsed.has(p.id)) {
            hidden.add(m.id);
            break;
          }
          p = p.parent ? byId.get(p.parent) : undefined;
        }
      }
      return hidden;
    }

    function relayout() {
      const hidden = hiddenIds();
      for (const m of metas) m.el.classList.toggle('hidden', hidden.has(m.id));
      for (const e of edgeEls) e.classList.toggle('hidden', hidden.has(e.dataset.edge!));

      const vis = metas.filter((m) => !hidden.has(m.id));
      const leaves = vis.filter(
        (m) => !(childrenOf.get(m.id) ?? []).some((k) => !hidden.has(k.id))
      );
      leaves.forEach((m, i) => {
        m.x = MARGIN + (i * (W - MARGIN * 2)) / (leaves.length - 1);
      });
      for (const m of [...vis].sort((a, b) => b.tier - a.tier)) {
        const kids = (childrenOf.get(m.id) ?? []).filter((k) => !hidden.has(k.id));
        if (kids.length) m.x = kids.reduce((s, k) => s + k.x, 0) / kids.length;
      }
      for (const m of metas) {
        if (hidden.has(m.id)) m.x = byId.get(m.parent!)?.x ?? m.x;
        m.el.style.transform = `translate(${m.x}px, ${TIER_Y[m.tier]}px)`;
      }

      for (const e of edgeEls) {
        const c = byId.get(e.dataset.edge!)!;
        const p = byId.get(c.parent!)!;
        const py = TIER_Y[p.tier]!;
        const cy = TIER_Y[c.tier]!;
        const midY = (py + cy) / 2;
        const d = `M ${p.x} ${py + p.r} L ${p.x} ${midY} L ${c.x} ${midY} L ${c.x} ${cy - c.r}`;
        e.setAttribute('d', d);
        e.style.setProperty('d', `path("${d}")`);
      }

      const anyExpanded = metas.some((m) => m.expandable && !collapsed.has(m.id));
      svg!.setAttribute('viewBox', `0 0 ${W} ${anyExpanded ? 560 : 470}`);
    }

    function focus(m: Meta) {
      const set = new Set([m.id]);
      let p = m.parent ? byId.get(m.parent) : undefined;
      while (p) {
        set.add(p.id);
        p = p.parent ? byId.get(p.parent) : undefined;
      }
      const sweep = (id: string) => {
        for (const k of childrenOf.get(id) ?? []) {
          set.add(k.id);
          sweep(k.id);
        }
      };
      sweep(m.id);

      svg!.classList.add('focused');
      for (const n of metas) n.el.classList.toggle('hl', set.has(n.id));
      for (const e of edgeEls) e.classList.toggle('hl', set.has(e.dataset.edge!));
      info!.replaceChildren();
      const name = document.createElement('strong');
      name.textContent = m.el.dataset.label!;
      info!.append(name, ` — ${m.el.dataset.blurb!}`);
    }

    for (const m of metas) {
      m.el.addEventListener('pointerenter', () => focus(m));
      if (m.expandable) {
        m.el.addEventListener('click', () => {
          const kids = (childrenOf.get(m.id) ?? []).length;
          if (collapsed.has(m.id)) {
            collapsed.delete(m.id);
            if (m.badge) m.badge.textContent = '−';
          } else {
            collapsed.add(m.id);
            if (m.badge) m.badge.textContent = `+${kids}`;
          }
          relayout();
          focus(m);
        });
      }
    }

    svg.addEventListener('pointerleave', () => svg.classList.remove('focused'));

    relayout();
  }
</script>
