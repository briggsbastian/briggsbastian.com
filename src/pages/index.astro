---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FleetTicker from '../components/FleetTicker.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GardenNote from '../components/GardenNote.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = projects.filter((p) => p.data.featured);

const notes = (await getCollection('garden'))
  .sort((a, b) => b.data.tended.valueOf() - a.data.tended.valueOf())
  .slice(0, 3);

const capabilities = [
  {
    name: 'Infrastructure as Code',
    detail: 'Five NixOS hosts described in one Nix flake and deployed with a single colmena apply. Any host can be rebuilt from scratch.',
  },
  {
    name: 'CI/CD & Release Engineering',
    detail: 'A self-hosted Forgejo pipeline that builds every host, scans for secrets, and only mirrors to the public repo on green, including the site you are reading.',
  },
  {
    name: 'Cloud',
    detail: 'The cloud leg is code: Terraform and nixos-anywhere stood up a Linode node in the same flake as the house, and tore it down just as cleanly — it is one apply from returning. Next is Azure at architect depth, AZ-104 under study now, AZ-305 behind it.',
  },
  {
    name: 'Secrets & Trust',
    detail: 'sops-nix secrets keyed to each host’s own SSH identity, a private step-ca CA issuing real certs to internal services, and a deploy user that can ship a closure but never open a root shell.',
  },
  {
    name: 'Observability',
    detail: 'A SIEM I tune at work; at home, a declarative Loki/Alloy stack that replaced Wazuh, every host shipping its journal, alert rules living in the same flake as the hosts they watch.',
  },
  {
    name: 'Security Engineering',
    detail: 'Threat modeling, hardening baselines, and least-privilege design, plus a libvirt range to attack the lab and prove the detections fire.',
  },
  {
    name: 'Networking',
    detail: 'An overall network guy: UniFi with VLAN segmentation across trusted, IoT, and guest, plus nftables host firewalls. At work, the same on Cisco, Meraki, SonicWall, Fortinet, and pfSense.',
  },
  {
    name: 'Declarative Recovery',
    detail: 'Every NixOS host is a generation you can roll back to, and a compromised box is rebuilt to known-good with one command.',
  },
];
---

<Base
  title="Briggs Bastian, Security & Systems Engineer"
  description="Self-driven engineer in Seattle who runs a security program by day, a NixOS homelab like it's production by night, and builds a souls-like game after hours."
>
  <section class="hero container">
    <p class="kicker">Briggs Bastian, Seattle, WA</p>
    <h1>Systems that hold<br />under <em>pressure</em>.</h1>
    <p class="lede">
      I'm a self-driven security analyst and engineer, happiest learning
      across the computer space, networking, infrastructure, wherever I'm
      needed. At work I run a security program. At home I run a NixOS homelab
      like it's production and build a souls-like game after hours.
    </p>
    <div class="hero-actions">
      <a class="btn" href="/projects/">See the work</a>
      <a class="btn ghost" href="/garden/">Wander the garden</a>
    </div>
    <dl class="stats">
      <div>
        <dt>years in security</dt>
        <dd data-count>04+</dd>
      </div>
      <div>
        <dt>hosts, one flake</dt>
        <dd data-count>05</dd>
      </div>
      <div>
        <dt>services on real certs</dt>
        <dd data-count>15</dd>
      </div>
    </dl>
    <FleetTicker />
  </section>

  <section class="section container">
    <div class="section-head" data-num="01">
      <div>
        <p class="kicker">Now building</p>
        <h2>Selected work</h2>
      </div>
      <a class="more" href="/projects/">All projects</a>
    </div>
    <div class="grid" data-accent="iris">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="02">
      <div>
        <p class="kicker">Operations</p>
        <h2>How I run things</h2>
      </div>
      <a class="more" href="/ops/">The receipts</a>
    </div>
    <div class="caps">
      {
        capabilities.map((cap, i) => (
          <div class="cap">
            <span class="cap-index">{String(i + 1).padStart(2, '0')}</span>
            <h3>{cap.name}</h3>
            <p>{cap.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="03">
      <div>
        <p class="kicker">Thought garden</p>
        <h2>Recently tended</h2>
      </div>
      <a class="more" href="/garden/">Enter the garden</a>
    </div>
    <div class="grid" data-accent="moss">
      {notes.map((note) => <GardenNote note={note} />)}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(3.5rem, 9vw, 6.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .hero h1 {
    font-size: clamp(3.5rem, 10.5vw, 8.5rem);
    margin-block: 1.25rem 1.75rem;
  }

  .hero h1 em {
    font-style: italic;
    -webkit-text-fill-color: var(--accent);
    filter: drop-shadow(0 0 18px color-mix(in srgb, var(--accent) 55%, transparent));
  }

  .hero .lede {
    font-size: 1.3rem;
    max-width: 44rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, auto);
    justify-content: start;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }

  .stats div {
    display: flex;
    /* column-reverse: number renders above label */
    flex-direction: column-reverse;
    border-left: 1px solid var(--line-bright);
    padding-left: 1.1rem;
  }

  .stats dd {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1;
    color: var(--accent);
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }

  .stats dd span {
    font-size: 0.6em;
  }

  .stats dt {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .caps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 2.5rem 3rem;
  }

  .cap-index {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .cap h3 {
    font-size: 1.45rem;
    margin-block: 0.5rem;
  }

  .cap p {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>

<script>
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    for (const dd of document.querySelectorAll<HTMLElement>('[data-count]')) {
      const textNode = dd.firstChild;
      if (!textNode || textNode.nodeType !== Node.TEXT_NODE) continue;
      const raw = textNode.textContent ?? '';
      const match = raw.match(/[\d.]+/);
      if (!match || match.index === undefined) continue;
      const target = parseFloat(match[0]);
      const decimals = (match[0].split('.')[1] ?? '').length;
      const pad = match[0].split('.')[0]!.length;
      const prefix = raw.slice(0, match.index);
      const suffix = raw.slice(match.index + match[0].length);
      const start = performance.now();
      const duration = 1100;
      const tick = (now: number) => {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const value = (target * eased).toFixed(decimals);
        const [int = '', dec] = value.split('.');
        textNode.textContent = prefix + int.padStart(pad, '0') + (dec ? `.${dec}` : '') + suffix;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }
</script>
