---
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'garden'>;
}

const { note } = Astro.props;
const { title, description, stage, planted, tended, topics } = note.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

// stage icons: seedling = sprout, budding = stem with bud, evergreen = pine
const stageIcon = {
  seedling: 'M9 16v-5 M9 11c0-3-2.5-4-4.5-4 0 3 2 4 4.5 4z M9 11c0-2 1.8-3.5 4-3.5 0 2.6-1.8 3.5-4 3.5z',
  budding: 'M9 16v-6 M9 10c0-2.5-2-3.5-4-3.5 0 2.7 1.8 3.5 4 3.5z M9 7.5a2.1 2.1 0 1 0 .01 0z',
  evergreen: 'M9 16v-2 M4 14h10L9 3z M5.5 10.5h7',
} as const;
---

<a class={`note ${stage}`} href={`/garden/${note.id}/`} data-spot data-stage={stage} data-topics={topics.join(' ')}>
  <header>
    <span class="stage">
      <svg viewBox="0 0 18 18" width="18" height="18" aria-hidden="true">
        <path d={stageIcon[stage]} />
      </svg>
      {stage}
    </span>
    <span class="dates" title={`planted ${fmt(planted)}`}>tended {fmt(tended)}</span>
  </header>
  <h3>{title}</h3>
  <p>{description}</p>
  {topics.length > 0 && (
    <ul class="topics">
      {topics.map((topic) => <li class="tag">{topic}</li>)}
    </ul>
  )}
</a>

<style>
  .note {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.6rem;
    border-radius: 14px;
    border: 1px solid var(--line);
    background:
      radial-gradient(220px circle at var(--mx, 50%) var(--my, 120%), var(--accent-glow), transparent 70%),
      linear-gradient(165deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.01));
    text-decoration: none;
    transition: border-color 150ms ease, transform 150ms ease, box-shadow 150ms ease;
  }

  /* stages read at a glance: seedlings are sketches, evergreens glow */
  .note.seedling {
    border-style: dashed;
  }

  .note.evergreen {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .note:hover {
    color: inherit;
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4), 0 0 24px var(--accent-glow);
  }

  .note:hover h3 {
    color: var(--accent-bright);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .stage {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .stage svg {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .dates {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--faint);
    white-space: nowrap;
  }

  h3 {
    font-size: 1.55rem;
    transition: color 120ms ease;
  }

  p {
    color: var(--muted);
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .topics {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
