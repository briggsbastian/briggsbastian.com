---
/*
 * TEMPORARY — theme comparison widget. Lets the user flip between
 * candidate themes live (persists via localStorage). Once a winner
 * is chosen: delete this component, its mount in Base.astro, the
 * early-restore script in Base.astro's <head>, and the losing
 * theme blocks in global.css.
 */
const THEMES = ['forge', 'midnight', 'ledger', 'slate'] as const;
---

<div class="theme-switcher" aria-label="Theme preview switcher">
  {THEMES.map((t) => <button data-theme-pick={t}>{t}</button>)}
</div>

<style>
  .theme-switcher {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 99;
    display: flex;
    gap: 2px;
    padding: 3px;
    background: var(--bg-overlay);
    border: 1px solid var(--line-bright);
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  button {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    background: transparent;
    border: none;
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    cursor: pointer;
  }

  button:hover {
    color: var(--text);
  }

  button.active {
    background: var(--accent);
    color: var(--bg);
  }
</style>

<script>
  const root = document.documentElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-pick]');

  function apply(theme: string) {
    if (theme === 'forge') {
      delete root.dataset.theme;
    } else {
      root.dataset.theme = theme;
    }
    localStorage.setItem('theme-preview', theme);
    for (const b of buttons) {
      b.classList.toggle('active', b.dataset.themePick === theme);
    }
  }

  for (const b of buttons) {
    b.addEventListener('click', () => apply(b.dataset.themePick!));
  }

  apply(localStorage.getItem('theme-preview') ?? 'forge');
</script>
