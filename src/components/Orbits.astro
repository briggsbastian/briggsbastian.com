---
/*
 * The observatory instrument: an orbital map of the site. The center
 * star is home; each orbiting body is a section, colored with its
 * accent and clickable. Pure CSS rotation, no JS.
 */
const rings = [
  { r: 62, dur: 26, c: 'iris', label: 'projects', href: '/projects/' },
  { r: 102, dur: 38, c: 'moss', label: 'garden', href: '/garden/' },
  { r: 142, dur: 52, c: 'brass', label: 'ops', href: '/ops/' },
  { r: 182, dur: 68, c: 'frost', label: 'resume', href: '/resume/' },
];
---

<div class="orbits">
  <svg viewBox="0 0 420 420" role="img" aria-label="Orbital map of the site's sections">
    {rings.map((ring) => <circle class="ring" cx="210" cy="210" r={ring.r} />)}
    <circle class="center-glow" cx="210" cy="210" r="22" />
    <circle class="center" cx="210" cy="210" r="6" />
    {rings.map((ring, i) => (
      <g class="orbit" style={`animation-duration: ${ring.dur}s; animation-delay: -${i * 9}s;`}>
        <a href={ring.href} aria-label={ring.label}>
          <circle class={`planet c-${ring.c}`} cx={210 + ring.r} cy="210" r="6.5" />
        </a>
      </g>
    ))}
  </svg>
  <ul class="legend">
    <li class="c-ember"><a href="/">home</a></li>
    {rings.map((ring) => (
      <li class={`c-${ring.c}`}>
        <a href={ring.href}>{ring.label}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  .orbits {
    display: grid;
    justify-items: center;
    gap: 0.75rem;
  }

  svg {
    width: min(100%, 26rem);
    height: auto;
  }

  .ring {
    fill: none;
    stroke: var(--line);
  }

  .center {
    fill: var(--ember);
  }

  .center-glow {
    fill: color-mix(in srgb, var(--ember) 18%, transparent);
  }

  .orbit {
    transform-box: view-box;
    transform-origin: 50% 50%;
    animation: orbit linear infinite;
  }

  @keyframes orbit {
    to {
      transform: rotate(360deg);
    }
  }

  .planet {
    fill: var(--c);
    filter: drop-shadow(0 0 7px var(--c));
    transition: r 150ms ease;
  }

  .orbit a:hover .planet {
    r: 9;
  }

  .c-ember { --c: var(--ember); }
  .c-iris  { --c: var(--iris); }
  .c-moss  { --c: var(--moss); }
  .c-brass { --c: var(--brass); }
  .c-frost { --c: var(--frost); }

  .legend {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.1rem;
  }

  .legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
  }

  .legend li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 6px var(--c);
  }

  .legend a {
    color: var(--muted);
    text-decoration: none;
  }

  .legend a:hover {
    color: var(--text);
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit {
      animation: none;
    }
  }
</style>
