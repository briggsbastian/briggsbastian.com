---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base
  title="Projects — Briggs Bastian"
  description="Infrastructure, security tooling, and a souls-like PvP game. Selected projects by Briggs Bastian."
>
  <section class="container intro">
    <p class="kicker">Projects</p>
    <h1>Things I'm building.</h1>
    <p class="lede">
      A mix of production infrastructure, security tooling, and one
      unreasonable game. Everything here is either running, shipping, or
      actively being forged.
    </p>
  </section>

  <section class="container">
    <div class="grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Base>

<style>
  .intro {
    padding-block: clamp(3rem, 8vw, 6rem);
  }

  .intro h1 {
    font-size: clamp(2.75rem, 7vw, 5rem);
    margin-block: 1rem 1.5rem;
  }

  .lede {
    max-width: 36rem;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr));
    gap: 1.25rem;
  }
</style>
