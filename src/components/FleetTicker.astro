---
// gen numbers illustrative, not a live feed
const hosts = [
  { name: 'desktop', gen: 412 },
  { name: 'mgmt', gen: 188 },
  { name: 'media', gen: 203 },
  { name: 'playground', gen: 97 },
  { name: 'hacktop', gen: 154 },
  { name: 'cloud1', gen: 9 },
];
---

<div class="ticker" role="group" aria-label="Homelab fleet: six NixOS hosts and their current generation numbers">
  <span class="rule" aria-hidden="true"></span>
  <ul>
    {hosts.map((h, i) => (
      <li style={`--i: ${i}`}>
        <span class="dot" aria-hidden="true"></span>
        <span class="host">{h.name}</span>
        <span class="gen">{h.gen}</span>
      </li>
    ))}
  </ul>
  <span class="rule" aria-hidden="true"></span>
</div>

<style>
  .ticker {
    display: flex;
    align-items: center;
    font-family: var(--mono);
    margin-top: clamp(3rem, 6vw, 4.5rem);
  }

  .rule {
    flex: 1;
    min-width: 1rem;
    height: 1px;
    background: var(--line-bright);
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem 1.7rem;
    list-style: none;
    margin: 0;
    padding: 0.6rem 1.5rem;
    border-inline: 1px solid var(--line-bright);
  }

  li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--moss);
    box-shadow: 0 0 6px var(--moss);
  }

  .host {
    color: var(--text);
  }

  .gen {
    color: var(--accent);
    font-size: 0.8em;
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: no-preference) {
    li {
      opacity: 0;
      animation: tick-in 420ms ease forwards;
      animation-delay: calc(var(--i) * 70ms + 150ms);
    }
  }

  @keyframes tick-in {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
