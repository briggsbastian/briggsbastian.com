---
import Base from '../layouts/Base.astro';

// media stays generic
const hosts = [
  { name: 'desktop', role: 'Workstation, and the Colmena deploy controller the fleet is pushed from', zone: 'lan' },
  { name: 'mgmt', role: 'Internal DNS, a private step-ca CA, Forgejo, the Harmonia binary cache, and the SIEM', zone: 'lan' },
  { name: 'media', role: 'The media stack, declaratively; storage mounted from the NAS over NFS', zone: 'lan' },
  { name: 'playground', role: 'libvirt security lab: Kali + Parrot, reached in-browser through Guacamole', zone: 'lan' },
  { name: 'hacktop', role: 'Staging host, the self-hosted Forgejo Actions runner, and the declarative ATMons Minecraft server', zone: 'lan' },
  { name: 'cloud1', role: 'Linode node: the WireGuard rendezvous and DNAT proxy publishing the game server — torn down and rebuilt from code', zone: 'cloud' },
  { name: 'nas', role: 'Ubuntu 24.04 over NFSv4.2; the one host I left off NixOS on purpose', zone: '–' },
];

const platform = [
  {
    name: 'One flake, one apply',
    detail: 'Six NixOS hosts plus an Ubuntu NAS live in a single Nix flake and deploy with colmena apply from one workstation. Adding a host means a new directory and one line; the Linode leg has come, gone, and come back exactly that way.',
  },
  {
    name: 'Provision vs. configure',
    detail: 'Terraform makes cloud boxes exist; nixos-anywhere wipes them to NixOS; Nix owns everything inside. Neither tool reaches into the other’s lifecycle.',
  },
  {
    name: 'A deploy user that can’t get a shell',
    detail: 'Colmena pushes closures as a dedicated deploy user, a Nix trusted-user with scoped NOPASSWD sudo for only the activation commands. A stolen deploy key re-runs a build; it never opens root.',
  },
  {
    name: 'Secrets keyed to the host',
    detail: 'sops-nix; each host decrypts its own secrets with its existing SSH host key via ssh-to-age. No key distribution, and no plaintext secret in the Nix store.',
  },
  {
    name: 'A private CA, wired into NixOS',
    detail: 'step-ca issues real, auto-renewing certificates to internal services over its own ACME endpoint. Trusting the root is a module a host opts into.',
  },
  {
    name: 'A public game, no open home ports',
    detail: 'Players hit play.briggsbastian.com on the Linode; nftables DNATs the flow down a WireGuard tunnel that hacktop dials out and keeps alive. No inbound holes at home, the home IP never published, and internet noise lands on the cloud box — at ~10–25 ms of added latency.',
  },
  {
    name: 'A SIEM defined in the flake',
    detail: 'Wazuh is out; a declarative Loki/Alloy/Alertmanager stack ships every host’s journal to mgmt, with alert rules in git and alerts pushed to a self-hosted ntfy topic. The cutover was gated on mgmt because it serves DNS and PKI.',
  },
];

const pipeline = [
  { stage: 'flake check', detail: 'nix flake check evaluates every host in the fleet. Bad config fails here, before anything is built.' },
  { stage: 'gitleaks', detail: 'Every push is scanned for secrets. The repo is mirrored publicly, so a leaked key is exposed the moment it lands.' },
  { stage: 'build all hosts', detail: 'A matrix builds every host against the Harmonia binary cache, fail-fast off. One broken host doesn’t hide the others.' },
  { stage: 'publish on green', detail: 'Only after the gates pass does a mirror job force-push to the public GitHub repo. Red commits stay in the private Forgejo and never reach the public mirror.' },
];

const signals = [
  { signal: 'Internal TLS', tells: 'Every internal service on a real step-ca cert, ~90-day, auto-renewed', state: 'live · 15 vhosts' },
  { signal: 'Fleet drift', tells: 'colmena apply is a clean no-op when a host matches the flake', state: 'live · equality check' },
  { signal: 'SIEM enrollment', tells: 'Every host shipping its journal to the homelab SIEM', state: 'live · Loki/Alloy' },
  { signal: 'Binary cache', tells: 'A green build hits the Harmonia cache instead of rebuilding', state: 'live' },
  { signal: 'Log retention', tells: 'Journals shipped to a central store, 30-day, single-tenant', state: 'live' },
  { signal: 'Availability SLOs + error budgets', tells: 'A number I’d actually defend a change against', state: 'not yet measured' },
];

const incidents = [
  {
    id: 'pki/dns-deadlock',
    date: 'Jun 15, 2026',
    title: 'Every internal service quietly served the wrong certificate for a day',
    impact:
      'All fifteen *.mgmt.lan services fell back to self-signed certs: trust warnings fleet-wide and the binary cache untrusted. No data exposed; step-ca itself was healthy.',
    lesson:
      'mgmt was resolving DNS upstream to 1.1.1.1, not its own AdGuard, so step-ca’s HTTP-01 ACME validation couldn’t resolve *.mgmt.lan to fetch challenges; every order failed and nginx fell back to minica. The box that serves DNS couldn’t use it to validate its own certs. Fix: pin the ACME domains to mgmt’s own IP in networkd-managed /etc/hosts, clear the stale renew units, redeploy. The same bootstrap deadlock is why Colmena deploys by IP rather than by the name AdGuard resolves.',
  },
  {
    id: 'drift/mgmt-channel',
    date: 'Jun 20, 2026',
    title: 'The box that runs the fleet had quietly stopped running the fleet’s config',
    impact:
      'Weeks of staged flake changes were never live on mgmt, and colmena apply --on mgmt then failed auth: the deploy user only exists in the flake, which wasn’t the active system.',
    lesson:
      'An unplanned nixos-rebuild had switched mgmt to a channel build, silently breaking Colmena management. Drift stays hidden until you go to deploy. Fix: re-fold carefully. Nix store diff-closures to confirm DNS/PKI weren’t in the diff, dry-activate to see what would restart, then switch on-box to recreate the deploy user and bring the flake live. Drift detection only works if you actually run the equality check, and the most-trusted box is the one worth checking most.',
  },
  {
    id: 'net/wifi-deploy',
    date: 'Jun 14–15, 2026',
    title: 'A deploy that restarts the network, on a box reachable only over the network',
    impact:
      'A channel downgrade restarted NetworkManager on the Wi-Fi-only hacktop; it dropped off Wi-Fi and didn’t reconnect. The closure applied fine; the box was just gone. A later dead Ethernet dongle black-holed the route and caused ARP flux, taking it fully offline.',
    lesson:
      'Know which deploys touch the link you’re standing on. Fix: pull the dead dongle to clear the ARP flux, redeploy from the no-git /tmp copy without bouncing NetworkManager, and promote “wire it to Ethernet with a static lease” to an action item. The fragile host is the one with no second route in.',
  },
  {
    id: 'cloud/kexec-oom',
    date: 'Jun 20, 2026',
    title: 'The first cloud node OOM’d in the middle of its own install',
    impact:
      'nixos-anywhere hung bringing up the first Linode node: a 1 GB Nanode couldn’t evaluate the NixOS closure in the in-RAM kexec environment.',
    lesson:
      'The fix was a terraform destroy and a bump to 2 GB. Greenfield NixOS installs need RAM headroom for the kexec; the smallest instance doesn’t leave enough for the install to fit.',
  },
];

const runbooks = [
  { name: 'host-wont-boot', trigger: 'A NixOS host is stuck after a config change', firstMove: 'Boot the previous generation from the bootloader menu, then colmena apply the known-good closure. That is what generations are for.' },
  { name: 'gated-mgmt-deploy', trigger: 'Any change to mgmt: DNS and PKI live here', firstMove: 'Never push blind: colmena apply --dry-activate first, check nix store diff-closures for DNS/PKI, keep nixos-rebuild --rollback ready, then apply.' },
  { name: 'deploy-with-secrets', trigger: 'A deploy needs sops secrets the flake can’t see', firstMove: 'Secrets are gitignored and flakes only read tracked files. Deploy from an rsync’d /tmp copy of the tree, not the dirty repo.' },
  { name: 'cert-not-trusted', trigger: 'An internal service is serving an untrusted cert', firstMove: 'Check mgmt is resolving through its own AdGuard, not upstream. ACME validation needs *.mgmt.lan to resolve locally before step-ca can issue.' },
  { name: 'drift-check', trigger: 'Unsure a host still matches its config', firstMove: 'colmena apply should be a no-op. If it isn’t, the host has drifted. Find out why before forcing the closure.' },
];
---

<Base
  title="Ops, Briggs Bastian"
  description="How Briggs Bastian runs a NixOS estate: the deploy model, the pipeline, the signals he watches, and the incidents that changed how it works."
  accent="brass"
>
  <section class="container intro">
    <p class="kicker">Operations</p>
    <h1>How it runs.</h1>
    <p class="lede">
      This page covers how my estate is actually deployed, the signals I
      watch, and the incidents I've caused and what they changed. It runs on a
      NixOS fleet I own and operate.
    </p>
  </section>

  <section class="container block">
    <div class="block-head" data-num="01"><p class="kicker">The estate</p></div>
    <p class="blurb">
      Five NixOS hosts on a UniFi network, a sixth off-site on Linode, and one
      Ubuntu NAS left off NixOS on purpose, all described in a single flake
      and deployed with one <code>colmena apply</code>. The Linode leg has
      already been torn down and rebuilt from code once — that's the point.
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Host</th>
            <th scope="col">Role</th>
            <th scope="col">Zone</th>
          </tr>
        </thead>
        <tbody>
          {hosts.map((h) => (
            <tr>
              <td class="mono">{h.name}</td>
              <td>{h.role}</td>
              <td class="mono">{h.zone}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <ol class="pipeline">
      {platform.map((item, i) => (
        <li class="panel" data-spot>
          <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{item.name}</h3>
            <p>{item.detail}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="container block">
    <div class="block-head" data-num="02"><p class="kicker">The pipeline</p></div>
    <p class="blurb">
      Changes to the infra repo run through a self-hosted Forgejo Actions
      pipeline on <code>hacktop</code>. Forgejo is the private source of
      truth; GitHub is the public mirror, and only green builds reach it.
    </p>
    <ol class="pipeline">
      {pipeline.map((step, i) => (
        <li class="panel" data-spot>
          <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{step.stage}</h3>
            <p>{step.detail}</p>
          </div>
        </li>
      ))}
    </ol>
    <p class="fleet-line">
      next: <strong>NixOS VM tests</strong>, boot a host in a VM and assert
      its services before a change touches real hardware · then
      <strong>merge-gated auto-deploy</strong> to the staging boxes. The
      runner holds deploy keys to the whole fleet, so it's treated as the most
      sensitive box on the network.
    </p>
  </section>

  <section class="container block">
    <div class="block-head" data-num="03"><p class="kicker">Signals</p></div>
    <p class="blurb">
      A signal is something you can check. These are the ones I watch; the
      last row is the one I don't measure yet.
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Signal</th>
            <th scope="col">What it tells me</th>
            <th scope="col">State</th>
          </tr>
        </thead>
        <tbody>
          {signals.map((row) => (
            <tr>
              <td class="mono">{row.signal}</td>
              <td>{row.tells}</td>
              <td class={row.state.startsWith('live') ? 'mono good' : 'mono'}>{row.state}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container block">
    <div class="block-head" data-num="04"><p class="kicker">Incidents &amp; postmortems</p></div>
    <p class="blurb">
      Blameless, pulled straight from the homelab log, each ending in a change
      that stuck.
    </p>
    <div class="incidents">
      {incidents.map((inc) => (
        <article class="incident panel" data-spot>
          <div class="inc-head">
            <span class="mono inc-id">{inc.id}</span>
            <span class="mono inc-date">{inc.date}</span>
          </div>
          <h3>{inc.title}</h3>
          <p><strong>Impact:</strong> {inc.impact}</p>
          <p><strong>What changed:</strong> {inc.lesson}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container block">
    <div class="block-head" data-num="05"><p class="kicker">Runbooks</p></div>
    <p class="blurb">
      If a failure mode is known, the response shouldn't be improvised.
      Runbooks live in the same repo as the configuration they describe, so the
      two version together.
    </p>
    <ul class="runbooks">
      {runbooks.map((rb) => (
        <li>
          <code class="rb-name">{rb.name}</code>
          <div>
            <p class="rb-trigger">Trigger: {rb.trigger}</p>
            <p class="rb-move">{rb.firstMove}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .block {
    padding-block: clamp(2.5rem, 6vw, 4rem);
    border-top: 1px solid var(--line);
  }

  .blurb {
    max-width: 40rem;
    color: var(--muted);
    margin-block: 0.75rem 2rem;
  }

  .blurb code {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--accent);
  }

  .mono {
    font-family: var(--mono);
    font-size: 0.8125rem;
  }

  .table-wrap {
    overflow-x: auto;
    margin-bottom: 2.25rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  th {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
    text-align: left;
    padding: 0.6rem 1rem 0.6rem 0;
    border-bottom: 1px solid var(--line-bright);
  }

  td {
    padding: 0.8rem 1rem 0.8rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    vertical-align: top;
  }

  td.good {
    color: var(--accent-bright);
  }

  .pipeline {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(16rem, 100%), 1fr));
    gap: 1.5rem;
  }

  .fleet-line {
    margin-top: 1.75rem;
    max-width: 46rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 1.9;
    color: var(--faint);
  }

  .fleet-line strong {
    color: var(--accent);
    font-weight: 500;
  }

  .pipeline li {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
  }

  .step-no {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .pipeline h3 {
    font-size: 1.3rem;
    margin-bottom: 0.4rem;
  }

  .pipeline p {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .incidents {
    display: grid;
    gap: 1.25rem;
  }

  .incident {
    max-width: 52rem;
    padding: 1.75rem;
    border-left: 2px solid var(--accent);
  }

  .inc-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .inc-id {
    color: var(--accent);
  }

  .inc-date {
    color: var(--faint);
  }

  .incident h3 {
    font-size: 1.45rem;
    margin-bottom: 0.75rem;
  }

  .incident p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .incident p + p {
    margin-top: 0.5rem;
  }

  .incident strong {
    color: var(--text);
    font-weight: 600;
  }

  .runbooks {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .runbooks li {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  .rb-name {
    color: var(--accent);
    font-size: 0.8125rem;
  }

  .rb-trigger {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--faint);
    margin-bottom: 0.3rem;
  }

  .rb-move {
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (max-width: 40rem) {
    .runbooks li {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
