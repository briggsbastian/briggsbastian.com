---
import Base from '../layouts/Base.astro';

/*
 * ── THE OPS PAGE: what it is and what makes it "real" ──────────────
 * This page is the DevOps legitimacy play. The thesis: anyone can list
 * "Kubernetes, Terraform, CI/CD" on a resume — almost nobody publishes
 * SLOs, postmortems, and runbooks. Those artifacts are how operators
 * recognize each other. Everything below is a MOCK shaped like the real
 * thing; each section's comment says what real artifact replaces it.
 *
 * TODO(briggs): every number, incident, and runbook on this page is
 * invented. Replace section by section as the homelab generates real
 * history. The structure is the part to keep.
 */

// SLOs — replace with targets you actually measure once monitoring is
// stood up. "Real" = each row backed by a recorded signal + an alert
// that fires when the error budget burns too fast (tool of your choice;
// NixRMM snapshots can carry several of these).
const slos = [
  { service: 'briggsbastian.com', slo: '99.9% availability', window: '30d', current: '100%', budget: 'untouched' },
  { service: 'UniFi network core', slo: '99.9% availability', window: '30d', current: '99.96%', budget: '24% burned' },
  { service: 'Media stack (Proxmox VMs)', slo: '99.5% availability', window: '30d', current: '99.74%', budget: '39% burned' },
  { service: 'Backups (NAS → offsite)', slo: 'RPO ≤ 24h, restore-tested monthly', window: '90d', current: 'RPO 8h', budget: 'last restore test: May 2026' },
];

// Pipeline — this one is mostly real already: it describes this site's
// own CI. Point each stage at the actual workflow once the repo is public.
const pipeline = [
  { stage: 'Typecheck', detail: 'astro check — schema-validated content; bad frontmatter fails the build, not the reader.' },
  { stage: 'Build', detail: 'Fully static output. The artifact that gets tested is the artifact that ships.' },
  { stage: 'Deploy', detail: 'GitHub Actions publishes main to Pages. No human hands between merge and production.' },
  { stage: 'Rollback', detail: 'git revert && git push. Recovery is the same pipeline, not a special ceremony.' },
];

// Postmortems — the highest-signal artifact on this page. One honest
// writeup of a real homelab failure beats ten capability claims.
// Format: blameless, timeline-aware, ends in a change that stuck.
const incidents = [
  {
    id: 'INC-2026-03',
    date: 'March 2026',
    title: 'Backup job + media library scan collided, saturating the NAS for 9 hours',
    impact: 'Backup RPO breached (31h vs 24h target). No data loss.',
    lesson:
      'The runbook was wrong — it predated the current storage layout. Fix: runbooks now live in the same repo as the configs they describe, and the monthly restore test exercises one runbook at random.',
  },
  {
    id: 'INC-2026-01',
    date: 'January 2026',
    title: 'UniFi firewall rule rollout cut management access to the Proxmox hosts',
    impact: 'Blind to the hypervisors for 47 minutes. Nothing actually failed — but the absence of green is not red.',
    lesson:
      'A firewall change passed review because the diff looked small. Fix: connectivity checks now run from both sides of every segment boundary after a change, and inter-network rule changes get a 5-minute auto-revert window unless confirmed.',
  },
];

// Reference architecture — MOCK until built. This is the SecDevOps
// learning target: a small Linode fleet that makes every claim on this
// page real. LEARNING_PATHWAY.md (repo root, untracked) maps each
// component to a build phase. TODO(briggs): as phases complete, this
// section stops being aspirational.
const platform = [
  {
    name: 'Provisioning as code',
    detail: 'OpenTofu drives the Linode API — instances, Cloud Firewalls, DNS, Object Storage. Infrastructure is a reviewed plan, never console clicks.',
  },
  {
    name: 'NixOS on rented metal',
    detail: 'Linode ships no NixOS image, so nixos-anywhere installs it over SSH. Every cloud node is a flake target: rebuilt, rolled back, and drift-checked like the homelab.',
  },
  {
    name: 'Supply-chain discipline',
    detail: 'CI builds containers, scans them, and pushes by digest — never :latest, never unscanned. The pipeline that deploys is the pipeline that gates.',
  },
  {
    name: 'No standing credentials',
    detail: 'Short-lived OIDC tokens where supported, tightly-scoped API tokens where not, and sops-encrypted secrets decrypted only on the target host.',
  },
  {
    name: 'One mesh, no exceptions',
    detail: 'WireGuard joins the Linode fleet to the homelab — cloud nodes are just more fleet. Management traffic never rides the public interface.',
  },
  {
    name: 'Offsite backups that restore',
    detail: 'restic ships NAS and cloud state to Linode Object Storage, encrypted client-side. The monthly restore test is what makes them backups instead of prayers.',
  },
];

// Runbooks — replace with links into the homelab repo (docs/ rendered or
// public excerpts). Title + trigger + first action is the legitimacy
// signal; full content can stay private.
const runbooks = [
  { name: 'nas-array-degraded', trigger: 'Disk/array health alert on the NAS', firstMove: 'Identify the failing disk before touching anything — rebuild beats restore.' },
  { name: 'gateway-unreachable', trigger: 'UniFi gateway offline from the trusted lan', firstMove: 'Console in locally before power-cycling. Find out why before you make it forget.' },
  { name: 'restore-test-monthly', trigger: 'Calendar, first Saturday', firstMove: 'Pick a random dataset, restore to scratch, diff against source. Untested backups are prayers.' },
  { name: 'nixos-vm-wont-boot', trigger: 'NixOS VM stuck after a config change', firstMove: 'Boot the previous generation from the Proxmox console — generations exist for exactly this.' },
];
---

<Base
  title="Ops — Briggs Bastian"
  description="SLOs, postmortems, and runbooks. How Briggs Bastian runs systems — the receipts, not the resume keywords."
  accent="brass"
>
  <section class="container intro">
    <p class="kicker">Operations</p>
    <h1>The receipts.</h1>
    <p class="lede">
      Anyone can put "CI/CD" on a resume. This page is the part that's hard
      to fake: the service levels I hold myself to, the incidents I've
      caused and what they changed, and the runbooks I reach for at 3 a.m.
      All of it from infrastructure I personally own and operate.
    </p>
  </section>

  <section class="container block">
    <div class="block-head" data-num="01"><p class="kicker">Service level objectives</p></div>
    <p class="blurb">
      Targets are promises with math. Each one needs a measured signal
      behind it, and the error budget — not my mood — decides whether the
      next change ships.
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Service</th>
            <th scope="col">Objective</th>
            <th scope="col">Window</th>
            <th scope="col">Current</th>
            <th scope="col">Error budget</th>
          </tr>
        </thead>
        <tbody>
          {slos.map((row) => (
            <tr>
              <td class="mono">{row.service}</td>
              <td>{row.slo}</td>
              <td class="mono">{row.window}</td>
              <td class="mono good">{row.current}</td>
              <td>{row.budget}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container block">
    <div class="block-head" data-num="02"><p class="kicker">The pipeline</p></div>
    <p class="blurb">
      This site ships itself — the pipeline below is the one that deployed
      the page you're reading. Merge to main is the only deploy button.
    </p>
    <ol class="pipeline">
      {pipeline.map((step, i) => (
        <li class="panel" data-spot>
          <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{step.stage}</h3>
            <p>{step.detail}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="container block">
    <div class="block-head" data-num="03"><p class="kicker">Incidents & postmortems</p></div>
    <p class="blurb">
      Blameless, written within a week, and each one ends in a change that
      stuck. An ops story without failures in it is a story about systems
      nobody was watching.
    </p>
    <div class="incidents">
      {incidents.map((inc) => (
        <article class="incident panel" data-spot>
          <div class="inc-head">
            <span class="mono inc-id">{inc.id}</span>
            <span class="mono inc-date">{inc.date}</span>
          </div>
          <h3>{inc.title}</h3>
          <p><strong>Impact:</strong> {inc.impact}</p>
          <p><strong>What changed:</strong> {inc.lesson}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container block">
    <div class="block-head" data-num="04"><p class="kicker">Reference architecture</p></div>
    <p class="blurb">
      The cloud half of the estate: a deliberately small Linode fleet,
      because SecDevOps is a set of habits, not a budget line. The pipeline
      and the perimeter are the same design problem — so they're designed
      together.
    </p>
    <ol class="pipeline platform">
      {platform.map((item, i) => (
        <li class="panel" data-spot>
          <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{item.name}</h3>
            <p>{item.detail}</p>
          </div>
        </li>
      ))}
    </ol>
    <p class="fleet-line">
      fleet: <strong>edge</strong> — Nanode 1GB · Caddy, Gatus, WireGuard ·
      <strong>forge</strong> — Linode 2GB · containers, game-server tests ·
      <strong>object storage</strong> — encrypted offsite backups.
      Total: the cost of two coffees a month.
    </p>
  </section>

  <section class="container block">
    <div class="block-head" data-num="05"><p class="kicker">Runbooks</p></div>
    <p class="blurb">
      If a failure mode is known, the response shouldn't be improvised.
      Runbooks live in the same repo as the configuration they describe —
      they version together or they drift apart.
    </p>
    <ul class="runbooks">
      {runbooks.map((rb) => (
        <li>
          <code class="rb-name">{rb.name}</code>
          <div>
            <p class="rb-trigger">Trigger: {rb.trigger}</p>
            <p class="rb-move">{rb.firstMove}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .block {
    padding-block: clamp(2.5rem, 6vw, 4rem);
    border-top: 1px solid var(--line);
  }

  .blurb {
    max-width: 38rem;
    color: var(--muted);
    margin-block: 0.75rem 2rem;
  }

  .mono {
    font-family: var(--mono);
    font-size: 0.8125rem;
  }

  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  th {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
    text-align: left;
    padding: 0.6rem 1rem 0.6rem 0;
    border-bottom: 1px solid var(--line-bright);
  }

  td {
    padding: 0.8rem 1rem 0.8rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    vertical-align: top;
  }

  td.good {
    color: var(--accent-bright);
  }

  .pipeline {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(16rem, 100%), 1fr));
    gap: 1.5rem;
  }

  .fleet-line {
    margin-top: 1.75rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 2;
    color: var(--faint);
  }

  .fleet-line strong {
    color: var(--accent);
    font-weight: 500;
  }

  .pipeline li {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
  }

  .step-no {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .pipeline h3 {
    font-size: 1.3rem;
    margin-bottom: 0.4rem;
  }

  .pipeline p {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .incidents {
    display: grid;
    gap: 1.25rem;
  }

  .incident {
    max-width: 50rem;
    padding: 1.75rem;
    border-left: 2px solid var(--accent);
  }

  .inc-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .inc-id {
    color: var(--accent);
  }

  .inc-date {
    color: var(--faint);
  }

  .incident h3 {
    font-size: 1.45rem;
    margin-bottom: 0.75rem;
  }

  .incident p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .incident p + p {
    margin-top: 0.5rem;
  }

  .incident strong {
    color: var(--text);
    font-weight: 600;
  }

  .runbooks {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .runbooks li {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0.5rem;
    border-bottom: 1px solid var(--line);
  }

  .rb-name {
    color: var(--accent);
    font-size: 0.8125rem;
  }

  .rb-trigger {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--faint);
    margin-bottom: 0.3rem;
  }

  .rb-move {
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (max-width: 40rem) {
    .runbooks li {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
