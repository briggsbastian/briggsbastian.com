---
interface NodeDef {
  id: string;
  label: string;
  c: string;
  r: number;
  blurb: string;
  parent?: string;
  collapsed?: boolean;
}

const RAW: NodeDef[] = [
  { id: 'internet', label: 'internet', c: 'none', r: 10, blurb: 'ISP uplink. Untrusted; everything below it is governed by policy.' },
  { id: 'gateway', label: 'unifi gateway', c: 'ember', r: 13, parent: 'internet', blurb: 'UniFi gateway: routing, firewall rules, and the segmentation between trusted, IoT, and guest all live here.' },
  { id: 'switch', label: 'unifi switching', c: 'none', r: 9, parent: 'gateway', blurb: 'UniFi switching fabric carrying the networks below.' },

  { id: 'lan', label: 'trusted lan', c: 'moss', r: 10, parent: 'switch', blurb: 'The trusted network: where the NixOS fleet lives, all of it deployed from one flake with a single colmena apply.' },
  { id: 'iot', label: 'iot', c: 'brass', r: 10, parent: 'switch', blurb: 'Streaming and smart-home devices, allowed out to the internet but not across to the LAN.' },
  { id: 'guest', label: 'guest', c: 'frost', r: 10, parent: 'switch', blurb: 'UniFi guest network: visitors get internet and nothing else.' },

  { id: 'desktop', label: 'desktop', c: 'iris', r: 8, parent: 'lan', blurb: 'NixOS workstation and gaming rig, also the deploy controller: colmena apply to the whole fleet runs from here.' },
  { id: 'mgmt', label: 'mgmt', c: 'iris', r: 8, parent: 'lan', blurb: 'NixOS services host: internal DNS, a private step-ca certificate authority, Forgejo, and the homelab SIEM, a declarative Loki/Alloy stack that replaced Wazuh. Folded into the flake last because the house leans on it.' },
  { id: 'media', label: 'media', c: 'iris', r: 8, parent: 'lan', blurb: 'NixOS media host: the stack runs declaratively from the flake, storage mounted from the NAS over NFS.' },

  { id: 'playground', label: 'playground', c: 'iris', r: 8, parent: 'lan', collapsed: true, blurb: 'NixOS + libvirt security lab: offensive and reverse-engineering VMs, reachable through an in-browser Guacamole session, isolated for purple-team work against the fleet. Click to expand.' },
  { id: 'vm-kali', label: 'kali', c: 'iris', r: 6, parent: 'playground', blurb: 'Kali Linux, live; the offensive box that attacks the lab to prove the SIEM catches it.' },
  { id: 'vm-parrot', label: 'parrot', c: 'iris', r: 6, parent: 'playground', blurb: 'ParrotOS, live; the second offensive distro in the kit.' },
  { id: 'vm-remnux', label: 'remnux', c: 'iris', r: 6, parent: 'playground', blurb: 'REMnux, next in; the Linux toolkit for tearing malware samples apart.' },
  { id: 'vm-flare', label: 'flare', c: 'iris', r: 6, parent: 'playground', blurb: 'FLARE VM (Windows), next in; the malware-analysis bench, TPM 2.0 emulated via swtpm under OVMF/UEFI.' },

  { id: 'hacktop', label: 'hacktop', c: 'iris', r: 8, parent: 'lan', blurb: 'NixOS staging + CI host: configs are built and verified here before they touch production, and it runs the self-hosted Forgejo Actions runner.' },
  { id: 'nas', label: 'nas · ubuntu', c: 'none', r: 8, parent: 'lan', blurb: 'Ubuntu 24.04 LTS NAS: bulk storage over NFSv4.2, and the one box kept off the NixOS fleet on purpose.' },
  { id: 'tv1', label: 'tv', c: 'brass', r: 8, parent: 'iot', blurb: 'Smart TV, quarantined on the IoT network.' },
  { id: 'tv2', label: 'tv', c: 'brass', r: 8, parent: 'iot', blurb: 'The other smart TV, on the same IoT network for the same reasons.' },
  { id: 'homepod', label: 'homepod', c: 'brass', r: 8, parent: 'iot', blurb: 'Apple HomePod, on the IoT network. Internet access only, no path to the LAN.' },
  { id: 'guests', label: 'guest devices', c: 'frost', r: 8, parent: 'guest', blurb: 'Whatever friends bring over, kept on the isolated guest network.' },
];

const W = 960;
const MARGIN = 72;
const TIER_Y = [46, 128, 210, 300, 398, 500];
const VIEW_H = { collapsed: 470, expanded: 560 };

const byId = new Map(RAW.map((n) => [n.id, n]));
const children = new Map<string, NodeDef[]>();
for (const n of RAW) {
  if (n.parent) children.set(n.parent, [...(children.get(n.parent) ?? []), n]);
}

const tierOf = (n: NodeDef): number => (n.parent ? tierOf(byId.get(n.parent)!) + 1 : 0);

const isHidden = (n: NodeDef): boolean => {
  let p = n.parent ? byId.get(n.parent) : undefined;
  while (p) {
    if (p.collapsed) return true;
    p = p.parent ? byId.get(p.parent) : undefined;
  }
  return false;
};

// hidden nodes park at parent so they emerge on expand
const visible = RAW.filter((n) => !isHidden(n));
const visLeaves = visible.filter(
  (n) => !(children.get(n.id) ?? []).some((k) => !isHidden(k))
);
const X = new Map<string, number>();
visLeaves.forEach((n, i) =>
  X.set(n.id, MARGIN + (i * (W - MARGIN * 2)) / (visLeaves.length - 1))
);
for (const n of [...visible].sort((a, b) => tierOf(b) - tierOf(a))) {
  const kids = (children.get(n.id) ?? []).filter((k) => !isHidden(k));
  if (kids.length) {
    X.set(n.id, kids.reduce((sum, k) => sum + X.get(k.id)!, 0) / kids.length);
  }
}
for (const n of RAW) {
  if (!X.has(n.id)) X.set(n.id, X.get(n.parent!)!);
}

const nodes = RAW.map((n, i) => ({
  ...n,
  tier: tierOf(n),
  x: X.get(n.id)!,
  y: TIER_Y[tierOf(n)]!,
  hidden: isHidden(n),
  kidCount: (children.get(n.id) ?? []).length,
  labelDy: tierOf(n) >= 4 && i % 2 ? 32 : 18,
}));

const edges = nodes
  .filter((n) => n.parent)
  .map((n) => {
    const p = nodes.find((m) => m.id === n.parent)!;
    const midY = (p.y + n.y) / 2;
    return {
      child: n,
      d: `M ${p.x} ${p.y + p.r} L ${p.x} ${midY} L ${n.x} ${midY} L ${n.x} ${n.y - n.r}`,
    };
  });
---

<figure class="topo">
  <div class="topo-scroll">
  <svg
    id="topo-svg"
    viewBox={`0 0 ${W} ${VIEW_H.collapsed}`}
    aria-label="Homelab network topology: tiered map from internet to devices"
    aria-describedby="topo-info"
  >
    <g>
      {edges.map((e) => (
        <path
          class:list={['edge', `c-${e.child.c}`, { hidden: e.child.hidden }]}
          d={e.d}
          data-edge={e.child.id}
          style={`--t: ${e.child.tier}`}
        />
      ))}
    </g>
    <g>
      {nodes.map((n) => (
        <g
          class:list={['node', `c-${n.c}`, { hidden: n.hidden }]}
          transform={`translate(${n.x} ${n.y})`}
          data-id={n.id}
          data-parent={n.parent}
          data-tier={n.tier}
          data-r={n.r}
          data-label={n.label}
          data-blurb={n.blurb}
          data-expandable={n.collapsed ? '1' : undefined}
          tabindex="0"
          role={n.collapsed ? 'button' : undefined}
          aria-expanded={n.collapsed ? 'false' : undefined}
          aria-label={n.label}
          style={`--t: ${n.tier}`}
        >
          <circle class="hit" r={n.r + 13} />
          <circle class="dot" r={n.r} />
          {n.id !== 'internet' && <circle class="up" cx={n.r * 0.8} cy={-n.r * 0.8} r="2.6" />}
          {n.collapsed && <text class="badge" x={n.r + 6} y="4">+{n.kidCount}</text>}
          <text y={n.r + n.labelDy}>{n.label}</text>
        </g>
      ))}
    </g>
  </svg>
  </div>
  <figcaption id="topo-info">
    Tap or hover a node to inspect it; select <strong>playground</strong> to expand its security-lab VMs. Green ticks are online status.
  </figcaption>
</figure>

<style is:global>
  .topo {
    margin: 2rem 0;
  }

  /* the glass frame stays put; the map pans inside it on small screens */
  .topo-scroll {
    background: var(--glass);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--glass-rim), var(--panel-shadow);
    overflow-x: auto;
    scrollbar-width: thin;
  }

  #topo-svg {
    display: block;
    width: 100%;
    height: auto;
    user-select: none;
  }

  @media (max-width: 44rem) {
    #topo-svg {
      /* keep labels legible on phones; the frame scrolls sideways instead */
      min-width: 52rem;
    }
  }

  #topo-svg .c-ember { --nc: var(--ember); }
  #topo-svg .c-iris  { --nc: var(--iris); }
  #topo-svg .c-moss  { --nc: var(--moss); }
  #topo-svg .c-frost { --nc: var(--frost); }
  #topo-svg .c-brass { --nc: var(--brass); }
  #topo-svg .c-none  { --nc: var(--faint); }

  #topo-svg .hidden {
    display: none;
  }

  #topo-svg .edge {
    fill: none;
    stroke: color-mix(in srgb, var(--nc) 32%, var(--line));
    stroke-width: 1.3;
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: topo-draw 700ms ease forwards;
    animation-delay: calc(var(--t) * 150ms);
    transition: opacity 150ms ease, stroke 150ms ease, d 450ms ease;
  }

  #topo-svg .node {
    cursor: default;
    opacity: 0;
    animation: topo-pop 500ms ease forwards;
    animation-delay: calc(var(--t) * 150ms);
    transition: opacity 150ms ease, transform 450ms ease;
  }

  #topo-svg .node[data-expandable] {
    cursor: pointer;
  }

  @keyframes topo-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes topo-pop {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    #topo-svg .edge,
    #topo-svg .node {
      animation: none;
      opacity: 1;
      stroke-dashoffset: 0;
      transition: none;
    }
  }

  #topo-svg .hit {
    fill: transparent;
  }

  #topo-svg .dot {
    fill: color-mix(in srgb, var(--nc) 22%, var(--bg));
    stroke: var(--nc);
    stroke-width: 1.5;
    transition: fill 150ms ease;
  }

  #topo-svg .up {
    fill: var(--moss);
    filter: drop-shadow(0 0 3px var(--moss));
  }

  #topo-svg text {
    font-family: var(--mono);
    font-size: 11px;
    fill: var(--muted);
    text-anchor: middle;
    pointer-events: none;
  }

  #topo-svg .badge {
    font-size: 9px;
    letter-spacing: 0.05em;
    fill: var(--nc);
    text-anchor: start;
  }

  /* focus: dim non-path */
  #topo-svg.focused .node:not(.hl) {
    opacity: 0.22;
  }

  #topo-svg.focused .edge:not(.hl) {
    opacity: 0.12;
  }

  #topo-svg .edge.hl {
    stroke: var(--accent);
  }

  #topo-svg .node.hl .dot {
    fill: color-mix(in srgb, var(--nc) 45%, var(--bg));
    filter: drop-shadow(0 0 6px var(--nc));
  }

  #topo-svg .node.hl text {
    fill: var(--text);
  }

  #topo-info {
    min-height: 3.25rem;
    padding: 0.85rem 0.25rem 0;
    font-size: 0.9rem;
    color: var(--muted);
  }

  #topo-info strong {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--accent);
  }
</style>

<script>
  const W = 960;
  const MARGIN = 72;
  const TIER_Y = [46, 128, 210, 300, 398, 500];

  const svg = document.querySelector<SVGSVGElement>('#topo-svg');
  const info = document.querySelector<HTMLElement>('#topo-info');

  if (svg && info) {
    interface Meta {
      id: string;
      el: SVGGElement;
      parent?: string;
      tier: number;
      r: number;
      expandable: boolean;
      badge: SVGTextElement | null;
      x: number;
    }

    const metas: Meta[] = [...svg.querySelectorAll<SVGGElement>('.node')].map((el) => ({
      id: el.dataset.id!,
      el,
      parent: el.dataset.parent || undefined,
      tier: Number(el.dataset.tier),
      r: Number(el.dataset.r),
      expandable: el.dataset.expandable === '1',
      badge: el.querySelector<SVGTextElement>('.badge'),
      x: 0,
    }));
    const byId = new Map(metas.map((m) => [m.id, m]));
    const childrenOf = new Map<string, Meta[]>();
    for (const m of metas) {
      if (m.parent) childrenOf.set(m.parent, [...(childrenOf.get(m.parent) ?? []), m]);
    }
    const edgeEls = [...svg.querySelectorAll<SVGPathElement>('.edge')];

    const collapsed = new Set(metas.filter((m) => m.expandable).map((m) => m.id));

    function hiddenIds() {
      const hidden = new Set<string>();
      for (const m of metas) {
        let p = m.parent ? byId.get(m.parent) : undefined;
        while (p) {
          if (collapsed.has(p.id)) {
            hidden.add(m.id);
            break;
          }
          p = p.parent ? byId.get(p.parent) : undefined;
        }
      }
      return hidden;
    }

    function relayout() {
      const hidden = hiddenIds();
      for (const m of metas) m.el.classList.toggle('hidden', hidden.has(m.id));
      for (const e of edgeEls) e.classList.toggle('hidden', hidden.has(e.dataset.edge!));

      const vis = metas.filter((m) => !hidden.has(m.id));
      const leaves = vis.filter(
        (m) => !(childrenOf.get(m.id) ?? []).some((k) => !hidden.has(k.id))
      );
      leaves.forEach((m, i) => {
        m.x = MARGIN + (i * (W - MARGIN * 2)) / (leaves.length - 1);
      });
      for (const m of [...vis].sort((a, b) => b.tier - a.tier)) {
        const kids = (childrenOf.get(m.id) ?? []).filter((k) => !hidden.has(k.id));
        if (kids.length) m.x = kids.reduce((s, k) => s + k.x, 0) / kids.length;
      }
      for (const m of metas) {
        if (hidden.has(m.id)) m.x = byId.get(m.parent!)?.x ?? m.x;
        m.el.style.transform = `translate(${m.x}px, ${TIER_Y[m.tier]}px)`;
      }

      for (const e of edgeEls) {
        const c = byId.get(e.dataset.edge!)!;
        const p = byId.get(c.parent!)!;
        const py = TIER_Y[p.tier]!;
        const cy = TIER_Y[c.tier]!;
        const midY = (py + cy) / 2;
        const d = `M ${p.x} ${py + p.r} L ${p.x} ${midY} L ${c.x} ${midY} L ${c.x} ${cy - c.r}`;
        e.setAttribute('d', d);
        e.style.setProperty('d', `path("${d}")`);
      }

      const anyExpanded = metas.some((m) => m.expandable && !collapsed.has(m.id));
      svg!.setAttribute('viewBox', `0 0 ${W} ${anyExpanded ? 560 : 470}`);
    }

    function focus(m: Meta) {
      const set = new Set([m.id]);
      let p = m.parent ? byId.get(m.parent) : undefined;
      while (p) {
        set.add(p.id);
        p = p.parent ? byId.get(p.parent) : undefined;
      }
      const sweep = (id: string) => {
        for (const k of childrenOf.get(id) ?? []) {
          set.add(k.id);
          sweep(k.id);
        }
      };
      sweep(m.id);

      svg!.classList.add('focused');
      for (const n of metas) n.el.classList.toggle('hl', set.has(n.id));
      for (const e of edgeEls) e.classList.toggle('hl', set.has(e.dataset.edge!));
      info!.replaceChildren();
      const name = document.createElement('strong');
      name.textContent = m.el.dataset.label!;
      info!.append(name, `, ${m.el.dataset.blurb!}`);
    }

    function toggle(m: Meta) {
      const kids = (childrenOf.get(m.id) ?? []).length;
      if (collapsed.has(m.id)) {
        collapsed.delete(m.id);
        if (m.badge) m.badge.textContent = '−';
        m.el.setAttribute('aria-expanded', 'true');
      } else {
        collapsed.add(m.id);
        if (m.badge) m.badge.textContent = `+${kids}`;
        m.el.setAttribute('aria-expanded', 'false');
      }
      relayout();
      focus(m);
    }

    for (const m of metas) {
      m.el.addEventListener('pointerenter', () => focus(m));
      m.el.addEventListener('focus', () => focus(m));
      if (m.expandable) {
        m.el.addEventListener('click', () => toggle(m));
        m.el.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            toggle(m);
          }
        });
      }
    }

    svg.addEventListener('pointerleave', () => svg.classList.remove('focused'));
    svg.addEventListener('focusout', (e) => {
      if (!svg.contains(e.relatedTarget as Node)) svg.classList.remove('focused');
    });

    relayout();

    // phones: the map overflows its frame — start the pan centered on the tree
    const wrap = svg.closest<HTMLElement>('.topo-scroll');
    if (wrap && wrap.scrollWidth > wrap.clientWidth) {
      wrap.scrollLeft = (wrap.scrollWidth - wrap.clientWidth) / 2;
    }
  }
</script>
