---
import '@fontsource/instrument-serif';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** accent per section: ember home, iris projects, moss garden, frost resume, brass ops */
  accent?: 'ember' | 'iris' | 'moss' | 'frost' | 'brass';
}

const { title, description, accent = 'ember' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
const isActive = (prefix: string) => path.startsWith(prefix);
---

<!doctype html>
<html lang="en" data-accent={accent}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="sky" aria-hidden="true"><div class="aurora"></div></div>
    <header>
      <nav class="container">
        <a class="wordmark" href="/">Briggs<span>&nbsp;Bastian</span></a>
        <div class="links">
          <a href="/projects/" class:list={['dot-iris', { active: isActive('/projects') }]}>Projects</a>
          <a href="/garden/" class:list={['dot-moss', { active: isActive('/garden') }]}>Garden</a>
          <a href="/ops/" class:list={['dot-brass', { active: isActive('/ops') }]}>Ops</a>
          <a href="/resume/" class:list={['dot-frost', { active: isActive('/resume') }]}>Resume</a>
          <a href="https://github.com/briggsbastian" target="_blank" rel="noopener">GitHub ↗</a>
        </div>
        <span class="status" aria-hidden="true"><i></i>SEA · 47.6°N</span>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container footer-inner">
        <div>
          <p class="kicker">Get in touch</p>
          <h2 class="footer-title">Say hello.</h2>
          <p class="footer-blurb">
            Open to interesting problems in infrastructure, security, and the
            occasional invader in the arena.
          </p>
        </div>
        <ul class="footer-links">
          <li>
            <a href="mailto:briggsbastian@pm.me">briggsbastian@pm.me</a>
            <button class="chip-btn copy" data-copy="briggsbastian@pm.me" aria-label="Copy email address">copy</button>
          </li>
          <li><a href="https://github.com/briggsbastian" target="_blank" rel="noopener">github.com/briggsbastian</a></li>
          <li><a href="https://linkedin.com/in/briggs-bastian" target="_blank" rel="noopener">linkedin.com/in/briggs-bastian</a></li>
        </ul>
      </div>
      <div class="container colophon">
        <span>© {new Date().getFullYear()} Briggs Bastian, Seattle, WA</span>
        <span>Built with Astro · Deployed from a Nix flake</span>
      </div>
    </footer>

    <script>
      document.addEventListener('pointermove', (e) => {
        const card = (e.target as Element | null)?.closest?.('[data-spot]') as HTMLElement | null;
        if (!card) return;
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });

      document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(btn.dataset.copy!);
            btn.textContent = 'copied ✓';
            btn.classList.add('done');
            setTimeout(() => {
              btn.textContent = 'copy';
              btn.classList.remove('done');
            }, 1600);
          } catch {
            btn.textContent = 'select it manually';
          }
        });
      });
    </script>

    <script>
      // html.js gates hidden state so no-js stays visible
      document.documentElement.classList.add('js');
      const targets = document.querySelectorAll('.hero, .intro, .section, .block');
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
        targets.forEach((t) => t.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.08 }
        );
        targets.forEach((t) => io.observe(t));
      }
    </script>
  </body>
</html>

<style>
  .sky {
    position: absolute;
    inset: 0 0 auto 0;
    height: 640px;
    pointer-events: none;
    overflow: hidden;
    z-index: -1;
    mask-image: linear-gradient(180deg, #000 0%, #000 50%, transparent 100%);
  }

  /* static: motion here flickers through glass blur */
  .aurora {
    position: absolute;
    inset: -25% -12% auto;
    height: 130%;
    background:
      radial-gradient(
        42% 48% at 76% 22%,
        color-mix(in srgb, var(--accent) 22%, transparent),
        transparent 70%
      ),
      radial-gradient(
        36% 44% at 18% 38%,
        color-mix(in srgb, var(--iris) 13%, transparent),
        transparent 70%
      );
    filter: blur(52px);
  }

  .sky::before,
  .sky::after {
    content: '';
    position: absolute;
    width: 1px;
    height: 1px;
    border-radius: 50%;
  }

  .sky::before {
    background: rgba(205, 216, 236, 0.5);
    box-shadow:
      4vw 64px rgba(205, 216, 236, 0.4), 9vw 312px rgba(205, 216, 236, 0.3),
      13vw 158px rgba(205, 216, 236, 0.45), 17vw 422px rgba(205, 216, 236, 0.25),
      22vw 88px rgba(205, 216, 236, 0.35), 26vw 248px rgba(205, 216, 236, 0.45),
      31vw 366px rgba(205, 216, 236, 0.3), 35vw 132px rgba(205, 216, 236, 0.4),
      40vw 458px rgba(205, 216, 236, 0.25), 44vw 36px rgba(205, 216, 236, 0.45),
      49vw 286px rgba(205, 216, 236, 0.3), 53vw 174px rgba(205, 216, 236, 0.4),
      58vw 398px rgba(205, 216, 236, 0.3), 62vw 102px rgba(205, 216, 236, 0.45),
      67vw 330px rgba(205, 216, 236, 0.25), 71vw 218px rgba(205, 216, 236, 0.4),
      76vw 56px rgba(205, 216, 236, 0.35), 80vw 442px rgba(205, 216, 236, 0.3),
      85vw 142px rgba(205, 216, 236, 0.45), 89vw 376px rgba(205, 216, 236, 0.25),
      94vw 256px rgba(205, 216, 236, 0.4), 98vw 76px rgba(205, 216, 236, 0.35),
      7vw 478px rgba(205, 216, 236, 0.25), 47vw 496px rgba(205, 216, 236, 0.2),
      91vw 488px rgba(205, 216, 236, 0.2);
  }

  .sky::after {
    background: rgba(232, 238, 252, 0.9);
    box-shadow:
      11vw 226px rgba(232, 238, 252, 0.7), 24vw 388px 1px rgba(232, 238, 252, 0.5),
      38vw 68px rgba(232, 238, 252, 0.8), 51vw 342px rgba(232, 238, 252, 0.6),
      64vw 186px 1px rgba(232, 238, 252, 0.55), 77vw 296px rgba(232, 238, 252, 0.7),
      90vw 118px rgba(232, 238, 252, 0.75), 18vw 48px 1px rgba(245, 168, 60, 0.5),
      70vw 432px rgba(157, 140, 255, 0.55), 33vw 472px rgba(232, 238, 252, 0.5),
      57vw 24px rgba(232, 238, 252, 0.65), 96vw 408px rgba(232, 238, 252, 0.45);
  }

  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg) 72%, transparent),
      color-mix(in srgb, var(--bg) 58%, transparent)
    );
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--line);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 0 -1px 0 rgba(255, 255, 255, 0.04),
      0 12px 32px rgba(4, 7, 14, 0.3);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    color: var(--faint);
    white-space: nowrap;
  }

  .status i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 3.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  @media (max-width: 52rem) {
    .status {
      display: none;
    }
  }

  /* phones: wordmark on its own row, links wrap full-width beneath it */
  @media (max-width: 40rem) {
    nav {
      flex-wrap: wrap;
      row-gap: 0.55rem;
      padding-block: 0.85rem;
    }

    .links {
      width: 100%;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 0.5rem 0.75rem;
    }

    .links a {
      font-size: 0.75rem;
      letter-spacing: 0.02em;
      gap: 0.35rem;
    }
  }

  .wordmark {
    font-family: var(--serif);
    font-size: 1.35rem;
    text-decoration: none;
    color: var(--text);
  }

  .wordmark span {
    color: var(--accent);
  }

  .links {
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .links a {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
  }

  .links a[class*='dot-']::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dot);
    box-shadow: 0 0 6px var(--dot);
  }

  .dot-iris  { --dot: var(--iris); }
  .dot-moss  { --dot: var(--moss); }
  .dot-brass { --dot: var(--brass); }
  .dot-frost { --dot: var(--frost); }

  .links a.active {
    color: var(--text);
  }

  .links a.active::after {
    transform: scaleX(1);
    background: var(--dot, var(--accent));
  }

  .links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -5px;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 220ms ease;
  }

  .links a:hover {
    color: var(--accent-bright);
  }

  .links a:hover::after {
    transform: scaleX(1);
  }

  footer {
    border-top: 1px solid var(--line);
    margin-top: clamp(4rem, 9vw, 7rem);
    background: var(--glass);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
    overflow: hidden;
  }

  @media (prefers-reduced-transparency: reduce) {
    header,
    footer {
      background: #0d1322;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  .footer-inner {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: end;
    gap: 2rem;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .footer-inner::before {
    content: 'BB';
    position: absolute;
    right: 0;
    bottom: -0.12em;
    font-family: var(--serif);
    font-size: clamp(9rem, 24vw, 18rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px var(--line-bright);
    opacity: 0.6;
    pointer-events: none;
  }

  .footer-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-block: 0.75rem;
  }

  .footer-blurb {
    color: var(--muted);
    max-width: 28rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.6rem;
    font-family: var(--mono);
    font-size: 0.875rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--accent-bright);
  }

  .copy {
    margin-left: 0.6rem;
    font-size: 0.6875rem;
    padding: 0.15rem 0.6rem;
  }

  .colophon {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    padding-block: 1.25rem;
    border-top: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--faint);
  }
</style>
