---
/*
 * Auvik-style structured topology: a tiered tree (internet → gateway →
 * switching → networks → devices) with elbow connectors, computed at
 * build time — the only client JS is hover focus + the info panel.
 * The media Proxmox host is described generically on purpose — keep it
 * that way.
 */

interface NodeDef {
  id: string;
  label: string;
  c: string;
  r: number;
  blurb: string;
  parent?: string;
}

const RAW: NodeDef[] = [
  { id: 'internet', label: 'internet', c: 'none', r: 10, blurb: 'ISP uplink. Untrusted by definition — everything below it is policy.' },
  { id: 'gateway', label: 'unifi gateway', c: 'ember', r: 13, parent: 'internet', blurb: 'UniFi gateway — routing, firewall rules, and the segmentation between trusted, IoT, and guest all live here.' },
  { id: 'switch', label: 'unifi switching', c: 'none', r: 9, parent: 'gateway', blurb: 'UniFi switching fabric carrying the networks below.' },

  { id: 'lan', label: 'trusted lan', c: 'moss', r: 10, parent: 'switch', blurb: 'The trusted network — where the fleet lives.' },
  { id: 'iot', label: 'iot', c: 'brass', r: 10, parent: 'switch', blurb: 'Streaming and smart-home devices. They talk out, not sideways.' },
  { id: 'guest', label: 'guest', c: 'frost', r: 10, parent: 'switch', blurb: 'UniFi guest network — visitors get internet and nothing else.' },

  { id: 'pve-media', label: 'pve · media', c: 'iris', r: 8, parent: 'lan', blurb: 'Proxmox host running NixOS VMs for the media stack — acquisition through playback.' },
  { id: 'pve-sec', label: 'pve · security', c: 'iris', r: 8, parent: 'lan', blurb: 'Proxmox host for the security VM deployment — where the day job’s instincts get a sandbox.' },
  { id: 'pve-net', label: 'pve · netmgmt', c: 'iris', r: 8, parent: 'lan', blurb: 'Proxmox host for network management VMs — keeping the UniFi estate observable and honest.' },
  { id: 'gaming', label: 'gaming rig', c: 'iris', r: 8, parent: 'lan', blurb: 'NixOS gaming desktop — proof the declarative life survives contact with GPU drivers.' },
  { id: 'gameserver', label: 'game server', c: 'iris', r: 8, parent: 'lan', blurb: 'GNOME NixOS box hosting game servers — where Gesture’s dedicated builds will land.' },
  { id: 'nas', label: 'nas · ubuntu', c: 'none', r: 8, parent: 'lan', blurb: 'Ubuntu 24.04 LTS NAS — bulk storage, and the one holdout from the NixOS takeover.' },
  { id: 'tv1', label: 'tv', c: 'brass', r: 8, parent: 'iot', blurb: 'Smart TV — quarantined on the IoT network like the chatty appliance it is.' },
  { id: 'tv2', label: 'tv', c: 'brass', r: 8, parent: 'iot', blurb: 'The other smart TV. Same quarantine, same reasons.' },
  { id: 'homepod', label: 'homepod', c: 'brass', r: 8, parent: 'iot', blurb: 'Apple HomePod. It needs to hear "set a timer," not see the lan.' },
  { id: 'guests', label: 'guest devices', c: 'frost', r: 8, parent: 'guest', blurb: 'Whatever friends bring over — captive, segregated, forgotten.' },
];

const W = 960;
const TIER_Y = [46, 136, 226, 318, 446];

const byId = new Map(RAW.map((n) => [n.id, n]));
const children = new Map<string, NodeDef[]>();
for (const n of RAW) {
  if (n.parent) children.set(n.parent, [...(children.get(n.parent) ?? []), n]);
}

const tierOf = (n: NodeDef): number => (n.parent ? tierOf(byId.get(n.parent)!) + 1 : 0);

// leaves evenly spaced; every parent centered over its children
const leaves = RAW.filter((n) => !children.has(n.id));
const X = new Map<string, number>();
const margin = 72;
leaves.forEach((n, i) => X.set(n.id, margin + (i * (W - margin * 2)) / (leaves.length - 1)));
for (const n of [...RAW].sort((a, b) => tierOf(b) - tierOf(a))) {
  if (children.has(n.id)) {
    const kids = children.get(n.id)!;
    X.set(n.id, kids.reduce((sum, k) => sum + X.get(k.id)!, 0) / kids.length);
  }
}

const nodes = RAW.map((n, i) => ({
  ...n,
  tier: tierOf(n),
  x: X.get(n.id)!,
  y: TIER_Y[tierOf(n)]!,
  // bottom-tier labels alternate depth to avoid collisions
  labelDy: tierOf(n) === 4 && i % 2 ? 32 : 18,
}));

const edges = nodes
  .filter((n) => n.parent)
  .map((n) => {
    const p = nodes.find((m) => m.id === n.parent)!;
    const midY = (p.y + n.y) / 2;
    return {
      child: n,
      d: `M ${p.x} ${p.y + p.r} L ${p.x} ${midY} L ${n.x} ${midY} L ${n.x} ${n.y - n.r}`,
    };
  });
---

<figure class="topo">
  <svg id="topo-svg" viewBox={`0 0 ${W} 520`} aria-label="Homelab network topology — tiered map from internet to devices">
    <g>
      {edges.map((e) => (
        <path
          class={`edge c-${e.child.c}`}
          d={e.d}
          data-edge={e.child.id}
          style={`--t: ${e.child.tier}`}
        />
      ))}
    </g>
    <g>
      {nodes.map((n) => (
        <g
          class={`node c-${n.c}`}
          transform={`translate(${n.x} ${n.y})`}
          data-id={n.id}
          data-parent={n.parent}
          data-label={n.label}
          data-blurb={n.blurb}
          style={`--t: ${n.tier}`}
        >
          <circle class="hit" r={n.r + 13} />
          <circle class="dot" r={n.r} />
          {n.id !== 'internet' && <circle class="up" cx={n.r * 0.8} cy={-n.r * 0.8} r="2.6" />}
          <text y={n.r + n.labelDy}>{n.label}</text>
        </g>
      ))}
    </g>
  </svg>
  <figcaption id="topo-info">Hover a node to inspect it. Green ticks are online status.</figcaption>
</figure>

<style is:global>
  .topo {
    margin: 2rem 0;
  }

  #topo-svg {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: 12px;
    user-select: none;
  }

  #topo-svg .c-ember { --nc: var(--ember); }
  #topo-svg .c-iris  { --nc: var(--iris); }
  #topo-svg .c-moss  { --nc: var(--moss); }
  #topo-svg .c-frost { --nc: var(--frost); }
  #topo-svg .c-brass { --nc: var(--brass); }
  #topo-svg .c-none  { --nc: var(--faint); }

  #topo-svg .edge {
    fill: none;
    stroke: color-mix(in srgb, var(--nc) 32%, var(--line));
    stroke-width: 1.3;
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: topo-draw 700ms ease forwards;
    animation-delay: calc(var(--t) * 150ms);
    transition: opacity 150ms ease, stroke 150ms ease;
  }

  #topo-svg .node {
    cursor: pointer;
    opacity: 0;
    animation: topo-pop 500ms ease forwards;
    animation-delay: calc(var(--t) * 150ms);
    transition: opacity 150ms ease;
  }

  @keyframes topo-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes topo-pop {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    #topo-svg .edge,
    #topo-svg .node {
      animation: none;
      opacity: 1;
      stroke-dashoffset: 0;
    }
  }

  #topo-svg .hit {
    fill: transparent;
  }

  #topo-svg .dot {
    fill: color-mix(in srgb, var(--nc) 22%, var(--bg));
    stroke: var(--nc);
    stroke-width: 1.5;
    transition: fill 150ms ease;
  }

  #topo-svg .up {
    fill: var(--moss);
    filter: drop-shadow(0 0 3px var(--moss));
  }

  #topo-svg text {
    font-family: var(--mono);
    font-size: 11px;
    fill: var(--muted);
    text-anchor: middle;
    pointer-events: none;
  }

  /* Focus mode: dim everything outside the hovered node's path */
  #topo-svg.focused .node:not(.hl) {
    opacity: 0.22;
  }

  #topo-svg.focused .edge:not(.hl) {
    opacity: 0.12;
  }

  #topo-svg .edge.hl {
    stroke: var(--accent);
  }

  #topo-svg .node.hl .dot {
    fill: color-mix(in srgb, var(--nc) 45%, var(--bg));
    filter: drop-shadow(0 0 6px var(--nc));
  }

  #topo-svg .node.hl text {
    fill: var(--text);
  }

  #topo-info {
    min-height: 3.25rem;
    padding: 0.85rem 0.25rem 0;
    font-size: 0.9rem;
    color: var(--muted);
  }

  #topo-info strong {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--accent);
  }
</style>

<script>
  const svg = document.querySelector<SVGSVGElement>('#topo-svg');
  const info = document.querySelector<HTMLElement>('#topo-info');

  if (svg && info) {
    const nodeEls = [...svg.querySelectorAll<SVGGElement>('.node')];
    const edgeEls = [...svg.querySelectorAll<SVGPathElement>('.edge')];
    const parentOf = new Map(nodeEls.map((el) => [el.dataset.id!, el.dataset.parent]));

    function related(id: string) {
      const set = new Set([id]);
      // ancestors
      let cur = parentOf.get(id);
      while (cur) {
        set.add(cur);
        cur = parentOf.get(cur);
      }
      // descendants (children reference parents, so sweep until stable)
      let grew = true;
      while (grew) {
        grew = false;
        for (const [child, parent] of parentOf) {
          if (parent && set.has(parent) && !set.has(child)) {
            set.add(child);
            grew = true;
          }
        }
      }
      return set;
    }

    for (const el of nodeEls) {
      el.addEventListener('pointerenter', () => {
        const set = related(el.dataset.id!);
        svg.classList.add('focused');
        for (const n of nodeEls) n.classList.toggle('hl', set.has(n.dataset.id!));
        for (const e of edgeEls) e.classList.toggle('hl', set.has(e.dataset.edge!));
        info.replaceChildren();
        const name = document.createElement('strong');
        name.textContent = el.dataset.label!;
        info.append(name, ` — ${el.dataset.blurb!}`);
      });
    }

    svg.addEventListener('pointerleave', () => svg.classList.remove('focused'));
  }
</script>
