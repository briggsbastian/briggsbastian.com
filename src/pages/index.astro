---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FleetTicker from '../components/FleetTicker.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GardenNote from '../components/GardenNote.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = projects.filter((p) => p.data.featured);

const notes = (await getCollection('garden'))
  .sort((a, b) => b.data.tended.valueOf() - a.data.tended.valueOf())
  .slice(0, 3);

const capabilities = [
  {
    name: 'Infrastructure as Code',
    detail: 'I describe six NixOS hosts in one flake and deploy them with one colmena apply — because I never want to rebuild a box from memory again.',
  },
  {
    name: 'CI/CD & Release Engineering',
    detail: 'I built the pipeline that gates this very page: typecheck, secret scan, Nix build. Nothing I push goes public unless every check is green.',
  },
  {
    name: 'Cloud',
    detail: 'I stood my Linode node up with Terraform, tore it down when it was idle, and rebuilt it from code the day a game server needed a public front door. Next I want Azure at architect depth — AZ-104 under study, AZ-305 behind it.',
  },
  {
    name: 'Secrets & Trust',
    detail: 'I keyed every host’s secrets to its own SSH identity, run a private CA that issues real certs to my internal services, and gave my deploy user just enough power to ship a build — never a root shell.',
  },
  {
    name: 'Observability',
    detail: 'I tune a SIEM at work; at home I replaced Wazuh with a Loki/Alloy stack so my alert rules live in git next to the hosts they watch. An alert I can’t act on is noise.',
  },
  {
    name: 'Security Engineering',
    detail: 'I attack my own network from a Kali box to prove the detections fire — and when the “compromised” host needs cleanup, my recovery is a rebuild.',
  },
  {
    name: 'Networking',
    detail: 'I’m the overall network guy: UniFi with VLAN segmentation across trusted, IoT, and guest at home, plus nftables host firewalls. At work, the same on Cisco, Meraki, SonicWall, Fortinet, and pfSense.',
  },
  {
    name: 'Declarative Recovery',
    detail: 'Every host I run is a generation I can roll back to. I have torn machines down on purpose just to watch them come back identical.',
  },
];
---

<Base
  title="Briggs Bastian, Security & Systems Engineer"
  description="Hi — I'm Briggs. I started on a SOC floor, now I run a company's security stack, and I still go home and attack my own network to prove the alerts fire."
>
  <section class="hero container">
    <div class="hero-grid">
      <div>
        <p class="kicker">Briggs Bastian, Seattle, WA</p>
        <h1>Hi — I'm<br /><em>Briggs</em>.</h1>
        <p class="lede">
          I started out triaging SIEM alerts on a SOC floor; now I run a
          company's security stack, and I still go home and attack my own
          network to prove the alerts fire. Systems that hold under pressure —
          that's the whole job. After hours it's Gesture, a 1v1 souls-like, and
          a modded Minecraft server for the friends.
        </p>
        <div class="hero-actions">
          <a class="btn" href="/projects/">See the work</a>
          <a class="btn ghost" href="/garden/">Wander the garden</a>
        </div>
        <div class="now">
          <p class="now-head">Now · July 2026</p>
          <ul>
            <li>studying for AZ-104, AZ-305 behind it</li>
            <li>running <a href="/projects/homelab/">All the Mons</a> for the friends</li>
            <li>building <a href="/projects/gesture/">Gesture</a>, a 1v1 souls-like</li>
            <li>tending <a href="/garden/">the garden</a> in public</li>
          </ul>
        </div>
      </div>
      <img
        class="portrait"
        src="/portrait.png"
        alt="Briggs Bastian"
        width="800"
        height="1000"
        loading="eager"
      />
    </div>
    <dl class="stats">
      <div>
        <dt>years of 3 a.m. alerts</dt>
        <dd data-count>04+</dd>
      </div>
      <div>
        <dt>hosts, one flake</dt>
        <dd data-count>06</dd>
      </div>
      <div>
        <dt>public postmortems</dt>
        <dd data-count>04</dd>
      </div>
    </dl>
    <FleetTicker />
    <p class="motto">NixOS is best for all use cases……</p>
  </section>

  <section class="section container">
    <div class="section-head" data-num="01">
      <div>
        <p class="kicker">Now building</p>
        <h2>Selected work</h2>
      </div>
      <a class="more" href="/projects/">All projects</a>
    </div>
    <div class="grid" data-accent="iris">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="02">
      <div>
        <p class="kicker">Operations</p>
        <h2>How I run things</h2>
      </div>
      <a class="more" href="/ops/">The receipts</a>
    </div>
    <div class="caps">
      {
        capabilities.map((cap, i) => (
          <div class="cap">
            <span class="cap-index">{String(i + 1).padStart(2, '0')}</span>
            <h3>{cap.name}</h3>
            <p>{cap.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="03">
      <div>
        <p class="kicker">Thought garden</p>
        <h2>Recently tended</h2>
      </div>
      <a class="more" href="/garden/">Enter the garden</a>
    </div>
    <div class="grid" data-accent="moss">
      {notes.map((note) => <GardenNote note={note} />)}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(3.5rem, 9vw, 6.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .hero-grid {
    display: grid;
    gap: 2rem;
  }

  .portrait {
    width: clamp(7.5rem, 16vw, 14rem);
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--line-bright);
    box-shadow: var(--glass-rim), var(--panel-shadow);
    /* placeholder until the real photo lands; swap public/portrait.png, keep ~4:5 */
    order: -1;
  }

  @media (min-width: 64rem) {
    .hero-grid {
      grid-template-columns: 1fr auto;
      gap: 3.5rem;
    }

    .portrait {
      order: 0;
      margin-top: 3.2rem;
    }
  }

  .hero h1 {
    font-size: clamp(3.5rem, 10.5vw, 8.5rem);
    margin-block: 1.25rem 1.75rem;
  }

  .hero h1 em {
    font-style: italic;
    -webkit-text-fill-color: var(--accent);
    filter: drop-shadow(0 0 18px color-mix(in srgb, var(--accent) 55%, transparent));
  }

  .hero .lede {
    font-size: 1.3rem;
    max-width: 44rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .now {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    font-family: var(--mono);
  }

  .now-head {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .now-head::before {
    content: '';
    display: inline-block;
    width: 1.6rem;
    height: 1px;
    background: var(--accent);
    vertical-align: middle;
    margin-right: 0.65rem;
  }

  .now ul {
    list-style: none;
    padding: 0;
    margin: 0.6rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .now li::before {
    content: '▸';
    color: var(--faint);
    margin-right: 0.6rem;
  }

  .now a {
    color: var(--text);
    text-decoration-color: var(--line-bright);
  }

  .now a:hover {
    color: var(--accent-bright);
  }

  .motto {
    margin-top: 1.1rem;
    text-align: center;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--faint);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, auto);
    justify-content: start;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }

  .stats div {
    display: flex;
    /* column-reverse: number renders above label */
    flex-direction: column-reverse;
    border-left: 1px solid var(--line-bright);
    padding-left: 1.1rem;
  }

  .stats dd {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1;
    color: var(--accent);
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }

  .stats dd span {
    font-size: 0.6em;
  }

  .stats dt {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .caps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 2.5rem 3rem;
  }

  .cap-index {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .cap h3 {
    font-size: 1.45rem;
    margin-block: 0.5rem;
  }

  .cap p {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>

<script>
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    for (const dd of document.querySelectorAll<HTMLElement>('[data-count]')) {
      const textNode = dd.firstChild;
      if (!textNode || textNode.nodeType !== Node.TEXT_NODE) continue;
      const raw = textNode.textContent ?? '';
      const match = raw.match(/[\d.]+/);
      if (!match || match.index === undefined) continue;
      const target = parseFloat(match[0]);
      const decimals = (match[0].split('.')[1] ?? '').length;
      const pad = match[0].split('.')[0]!.length;
      const prefix = raw.slice(0, match.index);
      const suffix = raw.slice(match.index + match[0].length);
      const start = performance.now();
      const duration = 1100;
      const tick = (now: number) => {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const value = (target * eased).toFixed(decimals);
        const [int = '', dec] = value.split('.');
        textNode.textContent = prefix + int.padStart(pad, '0') + (dec ? `.${dec}` : '') + suffix;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }
</script>
