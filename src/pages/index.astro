---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Orbits from '../components/Orbits.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GardenNote from '../components/GardenNote.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = projects.filter((p) => p.data.featured);

const notes = (await getCollection('garden'))
  .sort((a, b) => b.data.tended.valueOf() - a.data.tended.valueOf())
  .slice(0, 3);

// TODO(briggs): fluff — tune this list to the tools you actually want to claim.
const capabilities = [
  {
    name: 'Infrastructure as Code',
    detail: 'NixOS modules and flakes, Terraform. Whole fleets defined in a repo, rebuilt from scratch without fear.',
  },
  {
    name: 'CI/CD & Release Engineering',
    detail: 'GitHub Actions pipelines that build, test, scan, and ship — including the site you are reading.',
  },
  {
    name: 'Containers & Orchestration',
    detail: 'OCI images built reproducibly, deployed to Kubernetes or kept honest on plain systemd.',
  },
  {
    name: 'Observability',
    detail: 'SIEM pipelines at work, lean fleet snapshots at home. If it pages at 3 a.m., it should explain itself.',
  },
  {
    name: 'Security Engineering',
    detail: 'Threat modeling, hardening baselines, and least-privilege design — security as architecture, not audit.',
  },
  {
    name: 'Automation & Tooling',
    detail: 'Go, Python, and shell where appropriate. Internal tools with the polish of products.',
  },
];
---

<Base
  title="Briggs Bastian — Security & Systems Engineer"
  description="Security-minded systems engineer in Seattle. Building resilient infrastructure, a NixOS-native RMM, and a souls-like PvP game."
>
  <section class="hero container">
    <div class="hero-grid">
      <div>
        <p class="kicker">Briggs Bastian — Seattle, WA</p>
        <h1>Systems that hold<br />under <em>pressure</em>.</h1>
        <p class="lede">
          Security-minded systems engineer with a deep Linux background. I design
          infrastructure that survives bad days, automate the boring parts out of
          existence, and — after hours — build a souls-like where the netcode has
          to be as honest as the combat.
        </p>
        <div class="hero-actions">
          <a class="btn" href="/projects/">See the work</a>
          <a class="btn ghost" href="/garden/">Wander the garden</a>
        </div>
        {/* TODO(briggs): fluff numbers — replace with figures you can defend. */}
        <dl class="stats">
          <div>
            <dt>years in security ops</dt>
            <dd data-count>04+</dd>
          </div>
          <div>
            <dt>projects in flight</dt>
            <dd data-count>05</dd>
          </div>
          <div>
            <dt>availability target</dt>
            <dd data-count>99.9<span>%</span></dd>
          </div>
        </dl>
      </div>
      <Orbits />
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="01">
      <div>
        <p class="kicker">Now building</p>
        <h2>Selected work</h2>
      </div>
      <a class="more" href="/projects/">All projects</a>
    </div>
    <div class="grid" data-accent="iris">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="02">
      <div>
        <p class="kicker">Operations</p>
        <h2>How I run things</h2>
      </div>
      <a class="more" href="/ops/">The receipts</a>
    </div>
    <div class="caps">
      {
        capabilities.map((cap, i) => (
          <div class="cap">
            <span class="cap-index">{String(i + 1).padStart(2, '0')}</span>
            <h3>{cap.name}</h3>
            <p>{cap.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section container">
    <div class="section-head" data-num="03">
      <div>
        <p class="kicker">Thought garden</p>
        <h2>Recently tended</h2>
      </div>
      <a class="more" href="/garden/">Enter the garden</a>
    </div>
    <div class="grid" data-accent="moss">
      {notes.map((note) => <GardenNote note={note} />)}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }

  .hero-grid {
    display: grid;
    align-items: center;
    gap: 3rem;
  }

  @media (min-width: 64rem) {
    .hero-grid {
      grid-template-columns: 1.25fr 0.75fr;
    }
  }

  .hero h1 {
    font-size: clamp(3.25rem, 9vw, 7rem);
    margin-block: 1.25rem 1.75rem;
  }

  .hero h1 em {
    font-style: italic;
    -webkit-text-fill-color: var(--accent);
    filter: drop-shadow(0 0 18px color-mix(in srgb, var(--accent) 55%, transparent));
  }

  .hero .lede {
    font-size: 1.15rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, auto);
    justify-content: start;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }

  .stats div {
    display: flex;
    /* dt precedes dd semantically; the number renders on top */
    flex-direction: column-reverse;
    border-left: 1px solid var(--line-bright);
    padding-left: 1.1rem;
  }

  .stats dd {
    font-family: var(--serif);
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    line-height: 1;
    color: var(--accent);
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }

  .stats dd span {
    font-size: 0.6em;
  }

  .stats dt {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .caps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 2.5rem 3rem;
  }

  .cap-index {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .cap h3 {
    font-size: 1.45rem;
    margin-block: 0.5rem;
  }

  .cap p {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>

<script>
  // Hero stats count up on load (skipped under reduced motion).
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    for (const dd of document.querySelectorAll<HTMLElement>('[data-count]')) {
      const textNode = dd.firstChild;
      if (!textNode || textNode.nodeType !== Node.TEXT_NODE) continue;
      const raw = textNode.textContent ?? '';
      const match = raw.match(/[\d.]+/);
      if (!match || match.index === undefined) continue;
      const target = parseFloat(match[0]);
      const decimals = (match[0].split('.')[1] ?? '').length;
      const pad = match[0].split('.')[0]!.length;
      const prefix = raw.slice(0, match.index);
      const suffix = raw.slice(match.index + match[0].length);
      const start = performance.now();
      const duration = 1100;
      const tick = (now: number) => {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const value = (target * eased).toFixed(decimals);
        const [int = '', dec] = value.split('.');
        textNode.textContent = prefix + int.padStart(pad, '0') + (dec ? `.${dec}` : '') + suffix;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }
</script>
