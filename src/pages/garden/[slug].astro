---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import GardenNote from '../../components/GardenNote.astro';

export async function getStaticPaths() {
  const notes = await getCollection('garden');
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const stageGlyph = { seedling: '○', budding: '◐', evergreen: '●' } as const;

const { note } = Astro.props;
const { title, description, stage, planted, tended, topics } = note.data;
const { Content } = await render(note);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// related: shared-topic notes first, then most recently tended
const others = (await getCollection('garden')).filter((n) => n.id !== note.id);
const related = others
  .sort(
    (a, b) =>
      Number(b.data.topics.some((t) => topics.includes(t))) -
        Number(a.data.topics.some((t) => topics.includes(t))) ||
      b.data.tended.valueOf() - a.data.tended.valueOf()
  )
  .slice(0, 2);
---

<Base title={`${title} – Thought Garden`} description={description} accent="moss">
  <article class="container">
    <header>
      <p class="kicker"><a href="/garden/">Garden</a> / {stageGlyph[stage]} {stage}</p>
      <h1>{title}</h1>
      <div class="meta">
        <span>planted {fmt(planted)}</span>
        <span>last tended {fmt(tended)}</span>
        {topics.map((topic) => (
          <a class="tag" href={`/garden/?topic=${encodeURIComponent(topic)}`}>{topic}</a>
        ))}
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
    <p class="caveat">
      {stage === 'seedling' && 'A seedling, barely more than a planted thought. Expect it to change shape.'}
      {stage === 'budding' && 'A budding note, taking form, still being tended.'}
      {stage === 'evergreen' && 'An evergreen, as settled as anything in a garden gets.'}
    </p>

    {related.length > 0 && (
      <aside class="related">
        <p class="kicker">Elsewhere in the garden</p>
        <div class="grid related-grid">
          {related.map((n) => <GardenNote note={n} />)}
        </div>
      </aside>
    )}
  </article>
</Base>

<style>
  article {
    padding-block: clamp(3rem, 8vw, 5rem);
  }

  .kicker a {
    color: inherit;
    text-decoration: none;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-block: 1rem;
    max-width: 50rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    margin-block: 1.5rem 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--faint);
  }

  .meta a.tag {
    text-decoration: none;
    transition: border-color 120ms ease, color 120ms ease;
  }

  .meta a.tag:hover {
    border-color: var(--accent);
    color: var(--accent-bright);
  }

  .caveat {
    max-width: var(--prose);
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-style: italic;
    color: var(--faint);
    font-size: 0.95rem;
  }

  .related {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--line);
  }

  .related-grid {
    margin-top: 1.5rem;
    max-width: 46rem;
  }
</style>
